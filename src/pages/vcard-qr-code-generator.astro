---
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "vCard QR Code Generator - Share Contact Info Instantly";
const description =
    "Create a free static vCard QR code to share your phone, email, address, and social links. Standard compliant and processed securely in your browser.";
---

<BaseLayout title={title} description={description}>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <!-- Breadcrumb -->
        <nav class="flex text-xs text-slate-500 mb-6" aria-label="Breadcrumb">
            <ol class="inline-flex items-center space-x-1 md:space-x-3">
                <li class="inline-flex items-center">
                    <a href="/" class="hover:text-brand-600">Home</a>
                </li>
                <li>
                    <div class="flex items-center">
                        <svg
                            class="w-3 h-3 text-slate-400 mx-1"
                            fill="currentColor"
                            viewBox="0 0 20 20"
                            ><path
                                fill-rule="evenodd"
                                d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z"
                                clip-rule="evenodd"></path></svg
                        >
                        <span class="text-slate-400" aria-current="page"
                            >vCard QR Code Generator</span
                        >
                    </div>
                </li>
            </ol>
        </nav>

        <!-- Header -->
        <div class="text-center md:text-left mb-10">
            <h1
                class="text-3xl md:text-4xl font-extrabold text-slate-900 tracking-tight"
            >
                Free <span class="text-gradient">vCard QR Code Generator</span>
            </h1>
            <p class="text-slate-600 mt-2 max-w-2xl">
                Generate digital business cards that users can scan to save your
                contact information directly into their smartphone contact
                books. No manual typing required.
            </p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
            <!-- Left Column: Settings Form -->
            <div
                class="lg:col-span-7 bg-white rounded-2xl border border-slate-200/80 shadow-md p-6 md:p-8 space-y-4"
            >
                <!-- Input Group: Name & Organization -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <label
                            for="vc-name"
                            class="block text-xs font-bold text-slate-700 uppercase tracking-wider mb-1.5"
                            >Full Name *</label
                        >
                        <input
                            type="text"
                            id="vc-name"
                            class="w-full rounded-xl border border-slate-300 px-3.5 py-2.5 text-slate-800 placeholder-slate-400 focus:border-brand-500 focus:outline-none text-sm"
                            placeholder="e.g. John Doe"
                        />
                    </div>
                    <div>
                        <label
                            for="vc-org"
                            class="block text-xs font-bold text-slate-700 uppercase tracking-wider mb-1.5"
                            >Organization</label
                        >
                        <input
                            type="text"
                            id="vc-org"
                            class="w-full rounded-xl border border-slate-300 px-3.5 py-2.5 text-slate-800 placeholder-slate-400 focus:border-brand-500 focus:outline-none text-sm"
                            placeholder="e.g. Acme Corp"
                        />
                    </div>
                </div>

                <!-- Input Group: Title & Phone -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <label
                            for="vc-title"
                            class="block text-xs font-bold text-slate-700 uppercase tracking-wider mb-1.5"
                            >Job Title</label
                        >
                        <input
                            type="text"
                            id="vc-title"
                            class="w-full rounded-xl border border-slate-300 px-3.5 py-2.5 text-slate-800 placeholder-slate-400 focus:border-brand-500 focus:outline-none text-sm"
                            placeholder="e.g. Software Engineer"
                        />
                    </div>
                    <div>
                        <label
                            for="vc-phone"
                            class="block text-xs font-bold text-slate-700 uppercase tracking-wider mb-1.5"
                            >Phone Number</label
                        >
                        <input
                            type="tel"
                            id="vc-phone"
                            class="w-full rounded-xl border border-slate-300 px-3.5 py-2.5 text-slate-800 placeholder-slate-400 focus:border-brand-500 focus:outline-none text-sm"
                            placeholder="e.g. +1 (555) 123-4567"
                        />
                    </div>
                </div>

                <!-- Input Group: Email & Website -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <label
                            for="vc-email"
                            class="block text-xs font-bold text-slate-700 uppercase tracking-wider mb-1.5"
                            >Email Address</label
                        >
                        <input
                            type="email"
                            id="vc-email"
                            class="w-full rounded-xl border border-slate-300 px-3.5 py-2.5 text-slate-800 placeholder-slate-400 focus:border-brand-500 focus:outline-none text-sm"
                            placeholder="e.g. john.doe@example.com"
                        />
                    </div>
                    <div>
                        <label
                            for="vc-web"
                            class="block text-xs font-bold text-slate-700 uppercase tracking-wider mb-1.5"
                            >Website (URL)</label
                        >
                        <input
                            type="url"
                            id="vc-web"
                            class="w-full rounded-xl border border-slate-300 px-3.5 py-2.5 text-slate-800 placeholder-slate-400 focus:border-brand-500 focus:outline-none text-sm"
                            placeholder="e.g. https://example.com"
                        />
                    </div>
                </div>

                <!-- Address -->
                <div>
                    <label
                        for="vc-addr"
                        class="block text-xs font-bold text-slate-700 uppercase tracking-wider mb-1.5"
                        >Address</label
                    >
                    <input
                        type="text"
                        id="vc-addr"
                        class="w-full rounded-xl border border-slate-300 px-3.5 py-2.5 text-slate-800 placeholder-slate-400 focus:border-brand-500 focus:outline-none text-sm"
                        placeholder="e.g. 123 Main Street, New York, NY 10001"
                    />
                </div>

                <div class="flex space-x-3 pt-4">
                    <button
                        id="btn-generate"
                        class="brand-gradient hover:brand-gradient-hover text-white font-semibold px-6 py-3 rounded-xl shadow-md transition-colors flex-grow"
                    >
                        Generate vCard QR Code
                    </button>
                    <button
                        id="btn-reset"
                        class="border border-slate-300 hover:border-slate-400 hover:bg-slate-50 text-slate-600 px-4 py-3 rounded-xl transition-colors"
                    >
                        Reset
                    </button>
                </div>
            </div>

            <!-- Right Column: Live Preview Area -->
            <div class="lg:col-span-5 space-y-6">
                <div
                    class="bg-white rounded-2xl border border-slate-200/80 shadow-md p-6 flex flex-col items-center justify-center text-center"
                >
                    <h2 class="text-lg font-bold text-slate-900 mb-4">
                        Preview
                    </h2>

                    <div
                        class="p-6 bg-slate-50 border border-slate-150 rounded-xl relative flex items-center justify-center min-h-[260px] min-w-[260px]"
                    >
                        <div
                            id="preview-placeholder"
                            class="text-slate-400 text-sm flex flex-col items-center"
                        >
                            <svg
                                class="h-12 w-12 text-slate-300 mb-2 animate-pulse"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="1.5"
                            >
                                <rect x="3" y="3" width="18" height="18" rx="2"
                                ></rect>
                                <path
                                    d="M10 6H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V8a2 2 0 00-2-2h-5m-4 0V5a2 2 0 114 0v1"
                                ></path>
                            </svg>
                            <span>Fill fields and generate vCard QR</span>
                        </div>

                        <div id="qr-container" class="hidden">
                            <img
                                id="qr-image"
                                src=""
                                alt="vCard QR Code"
                                class="max-w-full h-auto mx-auto border shadow-sm rounded bg-white"
                            />
                        </div>
                    </div>

                    <div
                        id="action-buttons"
                        class="w-full grid grid-cols-2 gap-3 mt-6 hidden"
                    >
                        <button
                            id="btn-download-png"
                            class="flex items-center justify-center space-x-2 bg-slate-900 hover:bg-slate-800 text-white font-semibold py-2.5 px-4 rounded-xl shadow-sm transition-colors text-sm"
                        >
                            <svg
                                class="h-4 w-4"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                                stroke-width="2"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"
                                ></path>
                            </svg>
                            <span>Download PNG</span>
                        </button>

                        <button
                            id="btn-download-svg"
                            class="flex items-center justify-center space-x-2 border border-slate-300 hover:border-slate-400 hover:bg-slate-50 text-slate-700 font-semibold py-2.5 px-4 rounded-xl transition-colors text-sm"
                        >
                            <svg
                                class="h-4 w-4"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                                stroke-width="2"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"
                                ></path>
                            </svg>
                            <span>Download SVG</span>
                        </button>
                    </div>
                </div>

                <!-- Privacy Guard -->
                <div
                    class="bg-blue-50 border border-blue-100 rounded-2xl p-5 space-y-3"
                >
                    <h3
                        class="text-sm font-bold text-blue-900 flex items-center"
                    >
                        <svg
                            class="h-5 w-5 mr-1.5 text-blue-600"
                            viewBox="0 0 20 20"
                            fill="currentColor"
                        >
                            <path
                                fill-rule="evenodd"
                                d="M2.166 4.9c.773-.424 1.706-.5 2.54-.212l5.059 1.743c.154.053.322.053.476 0l5.059-1.743a3.003 3.003 0 013.737 3.327c-.244 2.458-1.127 5.064-5.32 8.04a.498.498 0 01-.58 0c-4.193-2.976-5.076-5.582-5.32-8.04a3.003 3.003 0 011.33-3.115z"
                                clip-rule="evenodd"></path>
                        </svg>
                        Contact Privacy Notice
                    </h3>
                    <p class="text-xs text-blue-800 leading-relaxed">
                        <strong
                            >Contact details are processed locally in your
                            browser.</strong
                        > Your personal name, phone numbers, and addresses are never
                        transmitted or stored online. Everything happens strictly
                        inside your device.
                    </p>
                </div>
            </div>
        </div>

        <!-- Instructions / Content Section -->
        <section
            class="mt-16 bg-white rounded-2xl border border-slate-200/80 p-8 md:p-10 space-y-8"
        >
            <div>
                <h2 class="text-2xl font-bold text-slate-900 mb-4">
                    What is a vCard QR Code?
                </h2>
                <p class="text-slate-600 leading-relaxed text-sm">
                    A vCard (Virtual Contact File) is a standard format for
                    electronic business cards. When written into a QR code,
                    modern mobile cameras immediately detect the card structure
                    and prompt the phone holder to "Create New Contact" or "Add
                    to Contacts". It allows physical business cards, banners, or
                    email signatures to bridges seamlessly to mobile phone
                    books.
                </p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <div>
                    <h3 class="text-lg font-bold text-slate-900 mb-3">
                        vCard 3.0 Specifications
                    </h3>
                    <p class="text-slate-600 leading-relaxed text-sm">
                        This tool generates contact lists using the widely
                        compatible <strong>vCard 3.0</strong> spec, supported natively
                        by Android's Contact manager, iOS Contacts, Microsoft Outlook,
                        and Gmail contacts directory.
                    </p>
                </div>
                <div>
                    <h3 class="text-lg font-bold text-slate-900 mb-3">
                        Why is the QR code so dense?
                    </h3>
                    <p class="text-slate-600 leading-relaxed text-sm">
                        vCard payloads contain multiple strings (name, email,
                        phone, organization, job description, address, etc.).
                        Because static QR codes store all characters physically
                        in the black dots, the grid will be more complex than
                        simple link QR codes. We recommend keeping descriptions
                        concise and downloading higher-resolution sizes (such as
                        512px or 1024px) for sharp printing.
                    </p>
                </div>
            </div>
        </section>
    </div>
</BaseLayout>

<script>
    import QRCode from "qrcode";

    const nameInput = document.getElementById("vc-name") as HTMLInputElement;
    const orgInput = document.getElementById("vc-org") as HTMLInputElement;
    const titleInput = document.getElementById("vc-title") as HTMLInputElement;
    const phoneInput = document.getElementById("vc-phone") as HTMLInputElement;
    const emailInput = document.getElementById("vc-email") as HTMLInputElement;
    const webInput = document.getElementById("vc-web") as HTMLInputElement;
    const addrInput = document.getElementById("vc-addr") as HTMLInputElement;

    const btnGenerate = document.getElementById(
        "btn-generate",
    ) as HTMLButtonElement;
    const btnReset = document.getElementById("btn-reset") as HTMLButtonElement;

    const previewPlaceholder = document.getElementById(
        "preview-placeholder",
    ) as HTMLDivElement;
    const qrContainer = document.getElementById(
        "qr-container",
    ) as HTMLDivElement;
    const qrImage = document.getElementById("qr-image") as HTMLImageElement;
    const actionButtons = document.getElementById(
        "action-buttons",
    ) as HTMLDivElement;
    const btnDownloadPng = document.getElementById(
        "btn-download-png",
    ) as HTMLButtonElement;
    const btnDownloadSvg = document.getElementById(
        "btn-download-svg",
    ) as HTMLButtonElement;

    let currentPngDataUrl = "";
    let currentSvgContent = "";

    function generateVCardCode() {
        const name = nameInput.value.trim();
        if (!name) {
            alert("Please enter at least a Full Name.");
            return;
        }

        const org = orgInput.value.trim();
        const title = titleInput.value.trim();
        const phone = phoneInput.value.trim();
        const email = emailInput.value.trim();
        const web = webInput.value.trim();
        const addr = addrInput.value.trim();

        // Assemble vCard 3.0 String
        let vCard = `BEGIN:VCARD\nVERSION:3.0\nFN:${name}\n`;
        if (org) vCard += `ORG:${org}\n`;
        if (title) vCard += `TITLE:${title}\n`;
        if (phone) vCard += `TEL;TYPE=CELL,VOICE:${phone}\n`;
        if (email) vCard += `EMAIL;TYPE=PREF,INTERNET:${email}\n`;
        if (web) vCard += `URL:${web}\n`;
        if (addr) vCard += `ADR;TYPE=WORK:;;${addr}\n`;
        vCard += "END:VCARD";

        try {
            QRCode.toDataURL(
                vCard,
                {
                    width: 380,
                    margin: 2,
                    errorCorrectionLevel: "M",
                    color: {
                        dark: "#000000",
                        light: "#ffffff",
                    },
                },
                (err, url) => {
                    if (err) throw err;
                    currentPngDataUrl = url;
                    qrImage.src = url;
                },
            );

            QRCode.toString(
                vCard,
                {
                    type: "svg",
                    width: 380,
                    margin: 2,
                    errorCorrectionLevel: "M",
                    color: {
                        dark: "#000000",
                        light: "#ffffff",
                    },
                },
                (err, svgString) => {
                    if (err) throw err;
                    currentSvgContent = svgString;
                },
            );

            previewPlaceholder.classList.add("hidden");
            qrContainer.classList.remove("hidden");
            actionButtons.classList.remove("hidden");
        } catch (e) {
            console.error(e);
            alert("Failed to generate vCard QR Code.");
        }
    }

    btnGenerate.addEventListener("click", generateVCardCode);

    btnReset.addEventListener("click", () => {
        nameInput.value = "";
        orgInput.value = "";
        titleInput.value = "";
        phoneInput.value = "";
        emailInput.value = "";
        webInput.value = "";
        addrInput.value = "";

        previewPlaceholder.classList.remove("hidden");
        qrContainer.classList.add("hidden");
        actionButtons.classList.add("hidden");
        qrImage.src = "";
        currentPngDataUrl = "";
        currentSvgContent = "";
    });

    btnDownloadPng.addEventListener("click", () => {
        if (!currentPngDataUrl) return;
        const link = document.createElement("a");
        link.href = currentPngDataUrl;
        link.download = `vcard-qr-${Date.now()}.png`;
        document.body.appendChild(link);
        link.click();
        document.body.removeChild(link);
    });

    btnDownloadSvg.addEventListener("click", () => {
        if (!currentSvgContent) return;
        const blob = new Blob([currentSvgContent], {
            type: "image/svg+xml;charset=utf-8",
        });
        const blobUrl = URL.createObjectURL(blob);
        const link = document.createElement("a");
        link.href = blobUrl;
        link.download = `vcard-qr-${Date.now()}.svg`;
        document.body.appendChild(link);
        link.click();
        document.body.removeChild(link);
        URL.revokeObjectURL(blobUrl);
    });
</script>
