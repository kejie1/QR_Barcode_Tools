---
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "QR Code Generator - Make a QR Code for a Website";
const description =
    "Make a QR code for a website URL, text, WiFi, or contact details. Create a free static QR code in your browser with no sign-up or tracking.";
---

<BaseLayout title={title} description={description}>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <!-- Breadcrumb -->
        <nav class="flex text-xs text-slate-500 mb-6" aria-label="Breadcrumb">
            <ol class="inline-flex items-center space-x-1 md:space-x-3">
                <li class="inline-flex items-center">
                    <a href="/" class="hover:text-brand-600">Home</a>
                </li>
                <li>
                    <div class="flex items-center">
                        <svg
                            class="w-3 h-3 text-slate-400 mx-1"
                            fill="currentColor"
                            viewBox="0 0 20 20"
                            ><path
                                fill-rule="evenodd"
                                d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z"
                                clip-rule="evenodd"></path></svg
                        >
                        <span class="text-slate-400" aria-current="page"
                            >QR Code Generator</span
                        >
                    </div>
                </li>
            </ol>
        </nav>

        <!-- H1 Header -->
        <div class="text-center md:text-left mb-10">
            <h1
                class="text-3xl md:text-4xl font-extrabold text-slate-900 tracking-tight"
            >
                Make a QR Code for a Website with a Free <span
                    class="text-gradient">QR Code Generator</span
                >
            </h1>
            <p class="text-slate-600 mt-2 max-w-2xl">
                Paste a website URL or text to create a static QR code in your
                browser. Customize size, colors, frame, and logo, then download
                a PNG or SVG without sign-up or tracking.
            </p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
            <!-- Left Column: Settings Form -->
            <div
                class="lg:col-span-7 bg-white rounded-2xl border border-slate-200/80 shadow-md p-6 md:p-8 space-y-6"
            >
                <div>
                    <div class="flex justify-between items-center mb-2">
                        <label
                            for="qr-content"
                            class="block text-sm font-bold text-slate-700"
                            >QR Code Content (Website URL or Text)</label
                        >
                        <button
                            id="btn-example"
                            class="text-xs font-semibold text-brand-600 hover:text-brand-700 transition-colors bg-brand-50 px-2 py-1 rounded"
                        >
                            Load Example
                        </button>
                    </div>
                    <textarea
                        id="qr-content"
                        rows="4"
                        class="w-full rounded-xl border border-slate-300 px-4 py-3 text-slate-800 placeholder-slate-400 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 focus:outline-none transition-all text-sm"
                        placeholder="Paste a website URL such as https://example.com..."
                    ></textarea>
                    <p
                        id="error-message"
                        class="text-xs text-red-500 mt-1 hidden font-semibold"
                    >
                    </p>
                </div>

                <details
                    class="group border-t border-slate-100 pt-4"
                >
                    <summary
                        class="flex cursor-pointer list-none items-center justify-between gap-3 rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 hover:border-brand-200 hover:bg-brand-50/50"
                    >
                        <div>
                            <h3 class="text-sm font-bold text-slate-700">
                                Advanced Options
                            </h3>
                            <p class="text-xs text-slate-500">
                                Size, colors, logo, design, and platform image options
                            </p>
                        </div>
                        <span
                            class="text-lg font-bold text-slate-400 transition-transform group-open:rotate-45"
                            >+</span
                        >
                    </summary>

                    <div class="space-y-6 pt-5">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <!-- Size -->
                    <div>
                        <label
                            for="qr-size"
                            class="block text-sm font-bold text-slate-700 mb-2"
                            >Size (pixels)</label
                        >
                        <select
                            id="qr-size"
                            class="w-full rounded-xl border border-slate-300 px-3 py-2 text-slate-700 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 focus:outline-none bg-white"
                        >
                            <option value="128">128 x 128</option>
                            <option value="256" selected>256 x 256</option>
                            <option value="512">512 x 512</option>
                            <option value="1024">1024 x 1024</option>
                        </select>
                    </div>

                    <!-- Error Correction -->
                    <div>
                        <label
                            for="qr-level"
                            class="block text-sm font-bold text-slate-700 mb-2"
                            >Error Correction Level</label
                        >
                        <select
                            id="qr-level"
                            class="w-full rounded-xl border border-slate-300 px-3 py-2 text-slate-700 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 focus:outline-none bg-white"
                        >
                            <option value="L">L (Low - 7% recovery)</option>
                            <option value="M" selected
                                >M (Medium - 15% recovery)</option
                            >
                            <option value="Q"
                                >Q (Quartile - 25% recovery)</option
                            >
                            <option value="H">H (High - 30% recovery)</option>
                        </select>
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <!-- Foreground Color -->
                    <div>
                        <label
                            for="qr-fg"
                            class="block text-sm font-bold text-slate-700 mb-2"
                            >Foreground Color</label
                        >
                        <div class="flex items-center space-x-3">
                            <input
                                type="color"
                                id="qr-fg"
                                value="#000000"
                                class="h-10 w-16 p-1 border border-slate-300 rounded-lg cursor-pointer bg-white"
                            />
                            <input
                                type="text"
                                id="qr-fg-text"
                                value="#000000"
                                class="w-full rounded-xl border border-slate-300 px-3 py-2 text-slate-700 text-sm focus:border-brand-500 focus:outline-none"
                            />
                        </div>
                    </div>

                    <!-- Background Color -->
                    <div>
                        <label
                            for="qr-bg"
                            class="block text-sm font-bold text-slate-700 mb-2"
                            >Background Color</label
                        >
                        <div class="flex items-center space-x-3">
                            <input
                                type="color"
                                id="qr-bg"
                                value="#ffffff"
                                class="h-10 w-16 p-1 border border-slate-300 rounded-lg cursor-pointer bg-white"
                            />
                            <input
                                type="text"
                                id="qr-bg-text"
                                value="#ffffff"
                                class="w-full rounded-xl border border-slate-300 px-3 py-2 text-slate-700 text-sm focus:border-brand-500 focus:outline-none"
                            />
                        </div>
                    </div>
                </div>

                <!-- QR Design Controls -->
                <div class="pt-4 border-t border-slate-100 space-y-5">
                    <div class="space-y-3">
                        <label
                            class="block text-xs font-semibold text-slate-500 uppercase tracking-wider"
                            >Frame Style</label
                        >
                        <div
                            class="grid grid-cols-2 sm:grid-cols-4 gap-3"
                            id="frame-options"
                        >
                            <button
                                type="button"
                                data-frame="none"
                                class="design-option active border border-brand-300 bg-brand-50 text-slate-800 rounded-xl p-3 text-xs font-semibold"
                                >No Frame</button
                            >
                            <button
                                type="button"
                                data-frame="caption-bottom"
                                class="design-option border border-slate-200 hover:border-brand-300 rounded-xl p-3 text-xs font-semibold"
                                >SCAN ME Bottom</button
                            >
                            <button
                                type="button"
                                data-frame="caption-top"
                                class="design-option border border-slate-200 hover:border-brand-300 rounded-xl p-3 text-xs font-semibold"
                                >SCAN ME Top</button
                            >
                            <button
                                type="button"
                                data-frame="card"
                                class="design-option border border-slate-200 hover:border-brand-300 rounded-xl p-3 text-xs font-semibold"
                                >Card Frame</button
                            >
                        </div>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <div>
                                <label
                                    for="frame-phrase"
                                    class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1.5"
                                    >Frame Phrase</label
                                >
                                <input
                                    id="frame-phrase"
                                    type="text"
                                    value="SCAN ME"
                                    maxlength="24"
                                    class="w-full rounded-xl border border-slate-300 px-3 py-2 text-slate-700 text-sm focus:border-brand-500 focus:outline-none"
                                />
                            </div>
                            <div>
                                <label
                                    for="frame-color"
                                    class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1.5"
                                    >Frame Color</label
                                >
                                <input
                                    id="frame-color"
                                    type="color"
                                    value="#0f172a"
                                    class="h-10 w-full p-1 border border-slate-300 rounded-lg cursor-pointer bg-white"
                                />
                            </div>
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="space-y-3">
                            <label
                                class="block text-xs font-semibold text-slate-500 uppercase tracking-wider"
                                >Module Shape</label
                            >
                            <div
                                class="grid grid-cols-4 gap-2"
                                id="module-shape-options"
                            >
                                <button
                                    type="button"
                                    data-shape="square"
                                    class="design-option active border border-brand-300 bg-brand-50 rounded-lg p-2 text-xs"
                                    >Square</button
                                >
                                <button
                                    type="button"
                                    data-shape="rounded"
                                    class="design-option border border-slate-200 hover:border-brand-300 rounded-lg p-2 text-xs"
                                    >Round</button
                                >
                                <button
                                    type="button"
                                    data-shape="circle"
                                    class="design-option border border-slate-200 hover:border-brand-300 rounded-lg p-2 text-xs"
                                    >Dots</button
                                >
                                <button
                                    type="button"
                                    data-shape="diamond"
                                    class="design-option border border-slate-200 hover:border-brand-300 rounded-lg p-2 text-xs"
                                    >Diamond</button
                                >
                            </div>
                        </div>

                        <div class="space-y-3">
                            <label
                                class="block text-xs font-semibold text-slate-500 uppercase tracking-wider"
                                >Finder Style</label
                            >
                            <div
                                class="grid grid-cols-3 gap-2"
                                id="finder-style-options"
                            >
                                <button
                                    type="button"
                                    data-finder="square"
                                    class="design-option active border border-brand-300 bg-brand-50 rounded-lg p-2 text-xs"
                                    >Square</button
                                >
                                <button
                                    type="button"
                                    data-finder="rounded"
                                    class="design-option border border-slate-200 hover:border-brand-300 rounded-lg p-2 text-xs"
                                    >Rounded</button
                                >
                                <button
                                    type="button"
                                    data-finder="circle"
                                    class="design-option border border-slate-200 hover:border-brand-300 rounded-lg p-2 text-xs"
                                    >Circle</button
                                >
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Logo Upload Section -->
                <div class="pt-4 border-t border-slate-100 space-y-4">
                    <h3 class="text-sm font-bold text-slate-700">
                        Add Custom Logo (Optional)
                    </h3>
                    <div class="space-y-3">
                        <label
                            class="block text-xs font-semibold text-slate-500 uppercase tracking-wider"
                            >Choose Common Icon</label
                        >
                        <div
                            id="preset-logo-options"
                            class="grid grid-cols-5 sm:grid-cols-8 lg:grid-cols-10 gap-2"
                        >
                            <button
                                type="button"
                                data-logo="none"
                                class="preset-logo active border border-brand-300 bg-brand-50 rounded-xl h-12 text-sm font-black"
                                title="No logo"
                                >X</button
                            >
                            <button
                                type="button"
                                data-logo="chat"
                                class="preset-logo border border-slate-200 hover:border-brand-300 rounded-xl h-12 text-sm font-black"
                                title="Chat"
                                >Q</button
                            >
                            <button
                                type="button"
                                data-logo="facebook"
                                class="preset-logo border border-slate-200 hover:border-brand-300 rounded-xl h-12 text-lg font-black"
                                title="Facebook"
                                >f</button
                            >
                            <button
                                type="button"
                                data-logo="twitter"
                                class="preset-logo border border-slate-200 hover:border-brand-300 rounded-xl h-12 text-xs font-black"
                                title="Twitter / X legacy"
                                >TW</button
                            >
                            <button
                                type="button"
                                data-logo="youtube"
                                class="preset-logo border border-slate-200 hover:border-brand-300 rounded-xl h-12 text-xs font-black"
                                title="YouTube"
                                >YT</button
                            >
                            <button
                                type="button"
                                data-logo="video"
                                class="preset-logo border border-slate-200 hover:border-brand-300 rounded-xl h-12 text-xs font-black"
                                title="Video"
                                >PLAY</button
                            >
                            <button
                                type="button"
                                data-logo="gplus"
                                class="preset-logo border border-slate-200 hover:border-brand-300 rounded-xl h-12 text-xs font-black"
                                title="Google Plus style"
                                >G+</button
                            >
                            <button
                                type="button"
                                data-logo="instagram"
                                class="preset-logo border border-slate-200 hover:border-brand-300 rounded-xl h-12 text-xs font-black"
                                title="Instagram"
                                >IG</button
                            >
                            <button
                                type="button"
                                data-logo="linkedin"
                                class="preset-logo border border-slate-200 hover:border-brand-300 rounded-xl h-12 text-xs font-black"
                                title="LinkedIn"
                                >in</button
                            >
                            <button
                                type="button"
                                data-logo="x"
                                class="preset-logo border border-slate-200 hover:border-brand-300 rounded-xl h-12 text-lg font-black"
                                title="X"
                                >X</button
                            >
                            <button
                                type="button"
                                data-logo="pinterest"
                                class="preset-logo border border-slate-200 hover:border-brand-300 rounded-xl h-12 text-lg font-black"
                                title="Pinterest"
                                >P</button
                            >
                            <button
                                type="button"
                                data-logo="vimeo"
                                class="preset-logo border border-slate-200 hover:border-brand-300 rounded-xl h-12 text-xs font-black"
                                title="Vimeo"
                                >V</button
                            >
                            <button
                                type="button"
                                data-logo="soundcloud"
                                class="preset-logo border border-slate-200 hover:border-brand-300 rounded-xl h-12 text-xs font-black"
                                title="SoundCloud"
                                >SC</button
                            >
                            <button
                                type="button"
                                data-logo="vk"
                                class="preset-logo border border-slate-200 hover:border-brand-300 rounded-xl h-12 text-xs font-black"
                                title="VK"
                                >VK</button
                            >
                            <button
                                type="button"
                                data-logo="whatsapp"
                                class="preset-logo border border-slate-200 hover:border-brand-300 rounded-xl h-12 text-xs font-black"
                                title="WhatsApp"
                                >WA</button
                            >
                            <button
                                type="button"
                                data-logo="app-store"
                                class="preset-logo border border-slate-200 hover:border-brand-300 rounded-xl h-12 text-xs font-black"
                                title="App Store"
                                >APP</button
                            >
                            <button
                                type="button"
                                data-logo="play-store"
                                class="preset-logo border border-slate-200 hover:border-brand-300 rounded-xl h-12 text-xs font-black"
                                title="Google Play"
                                >PLAY</button
                            >
                            <button
                                type="button"
                                data-logo="gmail"
                                class="preset-logo border border-slate-200 hover:border-brand-300 rounded-xl h-12 text-xs font-black"
                                title="Gmail / Email"
                                >MAIL</button
                            >
                            <button
                                type="button"
                                data-logo="calendar"
                                class="preset-logo border border-slate-200 hover:border-brand-300 rounded-xl h-12 text-xs font-black"
                                title="Calendar"
                                >CAL</button
                            >
                            <button
                                type="button"
                                data-logo="document"
                                class="preset-logo border border-slate-200 hover:border-brand-300 rounded-xl h-12 text-xs font-black"
                                title="Document"
                                >DOC</button
                            >
                            <button
                                type="button"
                                data-logo="viber"
                                class="preset-logo border border-slate-200 hover:border-brand-300 rounded-xl h-12 text-xs font-black"
                                title="Viber"
                                >VB</button
                            >
                            <button
                                type="button"
                                data-logo="share"
                                class="preset-logo border border-slate-200 hover:border-brand-300 rounded-xl h-12 text-xs font-black"
                                title="Share"
                                >SH</button
                            >
                            <button
                                type="button"
                                data-logo="wifi"
                                class="preset-logo border border-slate-200 hover:border-brand-300 rounded-xl h-12 text-xs font-black"
                                title="WiFi"
                                >WiFi</button
                            >
                            <button
                                type="button"
                                data-logo="bitcoin"
                                class="preset-logo border border-slate-200 hover:border-brand-300 rounded-xl h-12 text-lg font-black"
                                title="Bitcoin"
                                >B</button
                            >
                        </div>
                        <p class="text-xs text-slate-500">
                            Preset icons are generic text marks for QR center
                            styling. Upload your own official brand asset when
                            you need an exact logo.
                        </p>
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <!-- File upload -->
                        <div class="space-y-2">
                            <label
                                class="block text-xs font-semibold text-slate-500 uppercase tracking-wider"
                                >Upload Image</label
                            >
                            <div class="flex items-center space-x-3">
                                <label
                                    for="qr-logo"
                                    class="cursor-pointer inline-flex items-center space-x-2 bg-slate-100 hover:bg-slate-200 text-slate-700 font-semibold py-2 px-4 rounded-xl text-xs transition-colors border border-slate-300"
                                >
                                    <svg
                                        class="h-4 w-4 text-slate-500"
                                        fill="none"
                                        viewBox="0 0 24 24"
                                        stroke="currentColor"
                                        stroke-width="2"
                                    >
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"
                                        ></path>
                                    </svg>
                                    <span>Choose File</span>
                                </label>
                                <input
                                    type="file"
                                    id="qr-logo"
                                    accept="image/*"
                                    class="hidden"
                                />
                                <span
                                    id="logo-filename"
                                    class="text-xs text-slate-400 truncate max-w-[150px]"
                                    >No logo selected</span
                                >
                                <button
                                    id="btn-clear-logo"
                                    type="button"
                                    class="text-xs font-bold text-red-500 hover:text-red-600 hidden"
                                    >Remove</button
                                >
                            </div>
                        </div>

                        <!-- Logo Controls -->
                        <div class="space-y-3">
                            <div>
                                <label
                                    for="logo-size"
                                    class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1.5"
                                    >Logo Size (<span id="logo-size-val"
                                        >20</span
                                    >%)</label
                                >
                                <input
                                    type="range"
                                    id="logo-size"
                                    min="10"
                                    max="28"
                                    value="20"
                                    class="w-full h-2 bg-slate-200 rounded-lg appearance-none cursor-pointer accent-brand-500"
                                />
                            </div>
                            <div class="flex items-center">
                                <input
                                    type="checkbox"
                                    id="logo-border"
                                    checked
                                    class="h-4 w-4 rounded border-slate-300 text-brand-600 focus:ring-brand-200"
                                />
                                <label
                                    for="logo-border"
                                    class="ml-2 text-xs font-semibold text-slate-700 select-none"
                                    >Draw clear background border</label
                                >
                            </div>
                        </div>
                    </div>
                    <p class="text-[11px] text-slate-400 italic">
                        <strong>Tip:</strong> If you upload a logo, the generator
                        will automatically switch the <strong
                            >Error Correction Level to H (30%)</strong
                        >. This ensures the QR code is still readable with the
                        logo in the center.
                    </p>
                </div>

                <!-- Platform Background Section -->
                <div class="pt-4 border-t border-slate-100 space-y-4">
                    <h3 class="text-sm font-bold text-slate-700">
                        Platform Background Image (Optional)
                    </h3>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <label
                                for="platform-preset"
                                class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1.5"
                                >Platform Size</label
                            >
                            <select
                                id="platform-preset"
                                class="w-full rounded-xl border border-slate-300 px-3 py-2 text-slate-700 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 focus:outline-none bg-white"
                            >
                                <option value="none" selected
                                    >Plain QR only</option
                                >
                                <option value="instagram-post"
                                    >Instagram Post / Square - 1080 x 1080</option
                                >
                                <option value="story"
                                    >Instagram Story / Reels / TikTok - 1080 x 1920</option
                                >
                                <option value="youtube-thumbnail"
                                    >YouTube Thumbnail - 1280 x 720</option
                                >
                                <option value="social-landscape"
                                    >LinkedIn / Facebook / X Post - 1200 x 630</option
                                >
                            </select>
                        </div>

                        <div>
                            <label
                                for="platform-theme"
                                class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1.5"
                                >Background Theme</label
                            >
                            <select
                                id="platform-theme"
                                class="w-full rounded-xl border border-slate-300 px-3 py-2 text-slate-700 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 focus:outline-none bg-white"
                            >
                                <option value="blue" selected>Blue Clean</option>
                                <option value="dark">Dark Contrast</option>
                                <option value="mint">Mint Fresh</option>
                                <option value="warm">Warm Neutral</option>
                            </select>
                        </div>

                        <div>
                            <label
                                for="platform-title"
                                class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1.5"
                                >Headline</label
                            >
                            <input
                                id="platform-title"
                                type="text"
                                value="Scan to open"
                                maxlength="60"
                                class="w-full rounded-xl border border-slate-300 px-3 py-2 text-slate-700 text-sm focus:border-brand-500 focus:outline-none"
                            />
                        </div>

                        <div>
                            <label
                                for="platform-caption"
                                class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1.5"
                                >Caption</label
                            >
                            <input
                                id="platform-caption"
                                type="text"
