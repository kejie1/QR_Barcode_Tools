    });

    // 调节尺寸滑块
    logoSizeSlider.addEventListener("input", (e) => {
        const val = (e.target as HTMLInputElement).value;
        logoSizeValSpan.textContent = val;
    });
    logoSizeSlider.addEventListener("change", () => {
        generateQRCode();
    });
    logoBorderCheckbox.addEventListener("change", () => {
        generateQRCode();
    });

    [
        platformPresetSelect,
        platformThemeSelect,
        platformTitleInput,
        platformCaptionInput,
    ].forEach((element) => {
        element.addEventListener("input", () => {
            updatePlatformBackground();
        });
        element.addEventListener("change", () => {
            updatePlatformBackground();
        });
    });

    function drawRoundedRect(
        ctx: CanvasRenderingContext2D,
        x: number,
        y: number,
        width: number,
        height: number,
        radius: number,
    ) {
        ctx.beginPath();
        if (typeof ctx.roundRect === "function") {
            ctx.roundRect(x, y, width, height, radius);
        } else {
            ctx.moveTo(x + radius, y);
            ctx.lineTo(x + width - radius, y);
            ctx.quadraticCurveTo(x + width, y, x + width, y + radius);
            ctx.lineTo(x + width, y + height - radius);
            ctx.quadraticCurveTo(
                x + width,
                y + height,
                x + width - radius,
                y + height,
            );
            ctx.lineTo(x + radius, y + height);
            ctx.quadraticCurveTo(x, y + height, x, y + height - radius);
            ctx.lineTo(x, y + radius);
            ctx.quadraticCurveTo(x, y, x + radius, y);
        }
        ctx.closePath();
    }

    function wrapText(
        ctx: CanvasRenderingContext2D,
        text: string,
        maxWidth: number,
    ) {
        const words = text.split(/\s+/).filter(Boolean);
        const lines: string[] = [];
        let line = "";
        words.forEach((word) => {
            const nextLine = line ? `${line} ${word}` : word;
            if (ctx.measureText(nextLine).width > maxWidth && line) {
                lines.push(line);
                line = word;
            } else {
                line = nextLine;
            }
        });
        if (line) lines.push(line);
        return lines.slice(0, 3);
    }

    function loadImage(src: string) {
        return new Promise<HTMLImageElement>((resolve, reject) => {
            const img = new Image();
            img.onload = () => resolve(img);
            img.onerror = () => reject(new Error("Failed to load image."));
            img.src = src;
        });
    }

    function createPresetLogoDataUrl(preset: string) {
        if (preset === "none") return "";
        const config =
            presetLogoConfig[preset as keyof typeof presetLogoConfig] ??
            presetLogoConfig.chat;
        const canvas = document.createElement("canvas");
        canvas.width = 256;
        canvas.height = 256;
        const ctx = canvas.getContext("2d");
        if (!ctx) return "";
        ctx.fillStyle = config.bg;
        drawRoundedRect(ctx, 10, 10, 236, 236, 54);
        ctx.fill();
        ctx.fillStyle = config.fg;
        ctx.textAlign = "center";
        ctx.textBaseline = "middle";
        const isLongMark = config.icon.length > 2;
        ctx.font = isLongMark
            ? "900 54px Arial, sans-serif"
            : "900 112px Arial, sans-serif";
        ctx.fillText(config.icon, 128, 132);
        return canvas.toDataURL("image/png");
    }

    function isFinderModule(row: number, col: number, count: number) {
        const inTopLeft = row < 7 && col < 7;
        const inTopRight = row < 7 && col >= count - 7;
        const inBottomLeft = row >= count - 7 && col < 7;
        return inTopLeft || inTopRight || inBottomLeft;
    }

    function drawModule(
        ctx: CanvasRenderingContext2D,
        x: number,
        y: number,
        cell: number,
        shape: string,
        color: string,
    ) {
        const pad = cell * 0.08;
        ctx.fillStyle = color;
        if (shape === "circle") {
            ctx.beginPath();
            ctx.arc(x + cell / 2, y + cell / 2, cell * 0.42, 0, Math.PI * 2);
            ctx.fill();
            return;
        }
        if (shape === "rounded") {
            drawRoundedRect(
                ctx,
                x + pad,
                y + pad,
                cell - pad * 2,
                cell - pad * 2,
                cell * 0.24,
            );
            ctx.fill();
            return;
        }
        if (shape === "diamond") {
            ctx.beginPath();
            ctx.moveTo(x + cell / 2, y + pad);
            ctx.lineTo(x + cell - pad, y + cell / 2);
            ctx.lineTo(x + cell / 2, y + cell - pad);
            ctx.lineTo(x + pad, y + cell / 2);
            ctx.closePath();
            ctx.fill();
            return;
        }
        ctx.fillRect(x, y, cell, cell);
    }

    function drawFinder(
        ctx: CanvasRenderingContext2D,
        x: number,
        y: number,
        cell: number,
        style: string,
        fgColor: string,
        bgColor: string,
    ) {
        const size = cell * 7;
        const inner = cell * 3;
        const innerOffset = cell * 2;
        ctx.fillStyle = fgColor;
        if (style === "circle") {
            ctx.beginPath();
            ctx.arc(x + size / 2, y + size / 2, size / 2, 0, Math.PI * 2);
            ctx.fill();
            ctx.fillStyle = bgColor;
            ctx.beginPath();
            ctx.arc(x + size / 2, y + size / 2, cell * 2.25, 0, Math.PI * 2);
            ctx.fill();
            ctx.fillStyle = fgColor;
            ctx.beginPath();
            ctx.arc(x + size / 2, y + size / 2, inner / 2, 0, Math.PI * 2);
            ctx.fill();
            return;
        }
        const radius = style === "rounded" ? cell * 1.2 : 0;
        drawRoundedRect(ctx, x, y, size, size, radius);
        ctx.fill();
        ctx.fillStyle = bgColor;
        drawRoundedRect(ctx, x + cell, y + cell, cell * 5, cell * 5, radius * 0.7);
        ctx.fill();
        ctx.fillStyle = fgColor;
        drawRoundedRect(
            ctx,
            x + innerOffset,
            y + innerOffset,
            inner,
            inner,
            radius * 0.45,
        );
        ctx.fill();
    }

    function getQrModule(qr: any, row: number, col: number) {
        if (typeof qr.modules.get === "function") {
            return qr.modules.get(row, col);
        }
        return Boolean(qr.modules.data[row * qr.modules.size + col]);
    }

    async function renderStyledQrCanvas(
        content: string,
        size: number,
        level: "L" | "M" | "Q" | "H",
        fgColor: string,
        bgColor: string,
        logoDataUrl: string,
    ) {
        const qr = (QRCode as any).create(content, {
            errorCorrectionLevel: level,
        });
        const count = qr.modules.size;
        const marginCells = 4;
        const cell = Math.floor(size / (count + marginCells * 2));
        const qrSize = cell * (count + marginCells * 2);
        const frameStyle = activeFrameStyle;
        const framePhrase = framePhraseInput.value.trim() || "SCAN ME";
        const frameColor = frameColorInput.value || fgColor;
        const phraseHeight =
            frameStyle === "caption-top" || frameStyle === "caption-bottom"
                ? Math.round(qrSize * 0.16)
                : 0;
        const cardPadding = frameStyle === "card" ? Math.round(qrSize * 0.1) : 0;
        const canvas = document.createElement("canvas");
        canvas.width = qrSize + cardPadding * 2;
        canvas.height = qrSize + phraseHeight + cardPadding * 2;
        const ctx = canvas.getContext("2d");
        if (!ctx) return canvas;
        ctx.fillStyle = bgColor;
        ctx.fillRect(0, 0, canvas.width, canvas.height);

        if (frameStyle === "card") {
            ctx.fillStyle = frameColor;
            drawRoundedRect(ctx, 0, 0, canvas.width, canvas.height, qrSize * 0.08);
            ctx.fill();
            ctx.fillStyle = bgColor;
            drawRoundedRect(
                ctx,
                cardPadding * 0.45,
                cardPadding * 0.45,
                canvas.width - cardPadding * 0.9,
                canvas.height - cardPadding * 0.9,
                qrSize * 0.055,
            );
            ctx.fill();
        }

        if (frameStyle === "caption-top") {
            ctx.fillStyle = frameColor;
            ctx.font = `800 ${Math.round(phraseHeight * 0.42)}px Arial, sans-serif`;
            ctx.textAlign = "center";
            ctx.textBaseline = "middle";
            ctx.fillText(framePhrase, canvas.width / 2, phraseHeight / 2);
        }

        const offsetX = cardPadding;
        const offsetY =
            cardPadding + (frameStyle === "caption-top" ? phraseHeight : 0);
        ctx.fillStyle = bgColor;
        ctx.fillRect(offsetX, offsetY, qrSize, qrSize);

        for (let row = 0; row < count; row += 1) {
            for (let col = 0; col < count; col += 1) {
                if (!getQrModule(qr, row, col) || isFinderModule(row, col, count)) {
                    continue;
                }
                drawModule(
                    ctx,
                    offsetX + (col + marginCells) * cell,
                    offsetY + (row + marginCells) * cell,
                    cell,
                    activeModuleShape,
                    fgColor,
                );
            }
        }

        const finderPositions = [
            [0, 0],
            [0, count - 7],
            [count - 7, 0],
        ];
        finderPositions.forEach(([row, col]) => {
            drawFinder(
                ctx,
                offsetX + (col + marginCells) * cell,
                offsetY + (row + marginCells) * cell,
                cell,
                activeFinderStyle,
                fgColor,
                bgColor,
            );
        });

        if (logoDataUrl) {
            const logoImage = await loadImage(logoDataUrl);
            const logoPercent = parseInt(logoSizeSlider.value, 10) / 100;
            const logoSize = qrSize * logoPercent;
            const logoX = offsetX + (qrSize - logoSize) / 2;
            const logoY = offsetY + (qrSize - logoSize) / 2;
            if (logoBorderCheckbox.checked) {
                const padding = logoSize * 0.16;
                ctx.fillStyle = bgColor;
                drawRoundedRect(
                    ctx,
                    logoX - padding,
                    logoY - padding,
                    logoSize + padding * 2,
                    logoSize + padding * 2,
                    logoSize * 0.18,
                );
                ctx.fill();
            }
            ctx.drawImage(logoImage, logoX, logoY, logoSize, logoSize);
        }

        if (frameStyle === "caption-bottom") {
            ctx.fillStyle = frameColor;
            ctx.font = `800 ${Math.round(phraseHeight * 0.42)}px Arial, sans-serif`;
            ctx.textAlign = "center";
            ctx.textBaseline = "middle";
            ctx.fillText(
                framePhrase,
                canvas.width / 2,
                canvas.height - phraseHeight / 2,
            );
        }

        return canvas;
    }

    async function updatePlatformBackground() {
        const presetKey = platformPresetSelect.value as
            | "none"
            | keyof typeof platformPresets;
        if (presetKey === "none" || !currentPngDataUrl) {
            platformPreviewCard.classList.add("hidden");
            platformPreviewImage.src = "";
            currentPlatformDataUrl = "";
            return;
        }

        const preset = platformPresets[presetKey];
        const theme =
            platformThemes[platformThemeSelect.value as keyof typeof platformThemes] ??
            platformThemes.blue;
        const canvas = document.createElement("canvas");
        canvas.width = preset.width;
        canvas.height = preset.height;
        const ctx = canvas.getContext("2d");
        if (!ctx) return;

        const gradient = ctx.createLinearGradient(0, 0, preset.width, preset.height);
        gradient.addColorStop(0, theme.start);
        gradient.addColorStop(1, theme.end);
        ctx.fillStyle = gradient;
        ctx.fillRect(0, 0, preset.width, preset.height);

        ctx.fillStyle = "rgba(255, 255, 255, 0.22)";
        ctx.beginPath();
        ctx.arc(preset.width * 0.18, preset.height * 0.18, preset.width * 0.18, 0, Math.PI * 2);
        ctx.fill();
        ctx.fillStyle = "rgba(255, 255, 255, 0.14)";
        ctx.beginPath();
        ctx.arc(preset.width * 0.86, preset.height * 0.82, preset.width * 0.22, 0, Math.PI * 2);
        ctx.fill();

        const isTall = preset.height > preset.width;
        const isWide = preset.width / preset.height > 1.5;
        const safeMargin = Math.round(Math.min(preset.width, preset.height) * 0.075);
        const qrSize = Math.round(
            isTall
                ? preset.width * 0.62
                : isWide
                  ? preset.height * 0.44
                  : preset.width * 0.42,
        );
        const cardPadding = Math.round(qrSize * 0.1);
        const cardSize = qrSize + cardPadding * 2;
        const qrImageForPoster = await loadImage(currentPngDataUrl);

        let cardX = Math.round((preset.width - cardSize) / 2);
        let cardY = Math.round(preset.height * 0.42);
        if (isWide) {
            cardX = preset.width - safeMargin - cardSize;
            cardY = Math.round((preset.height - cardSize) / 2);
        }

        ctx.shadowColor = "rgba(15, 23, 42, 0.18)";
        ctx.shadowBlur = Math.round(cardSize * 0.05);
        ctx.shadowOffsetY = Math.round(cardSize * 0.025);
        ctx.fillStyle = theme.card;
        drawRoundedRect(ctx, cardX, cardY, cardSize, cardSize, Math.round(cardSize * 0.08));
        ctx.fill();
        ctx.shadowColor = "transparent";
        ctx.drawImage(
            qrImageForPoster,
            cardX + cardPadding,
            cardY + cardPadding,
            qrSize,
            qrSize,
        );

        const headline = platformTitleInput.value.trim() || "Scan to open";
        const caption =
            platformCaptionInput.value.trim() || "Created with QR Barcode Tools";
        const textX = isWide ? safeMargin : safeMargin;
        const textMaxWidth = isWide
            ? cardX - safeMargin * 2
            : preset.width - safeMargin * 2;
        const titleFontSize = Math.round(
            isTall ? preset.width * 0.08 : isWide ? preset.height * 0.085 : preset.width * 0.065,
        );
        const captionFontSize = Math.round(titleFontSize * 0.34);
        const titleY = isWide ? Math.round(preset.height * 0.28) : safeMargin + titleFontSize;

        ctx.textAlign = "left";
        ctx.fillStyle = theme.title;
        ctx.font = `800 ${titleFontSize}px Arial, sans-serif`;
        const headlineLines = wrapText(ctx, headline, textMaxWidth);
        headlineLines.forEach((line, index) => {
            ctx.fillText(line, textX, titleY + index * titleFontSize * 1.08);
        });

        ctx.fillStyle = theme.text;
        ctx.font = `600 ${captionFontSize}px Arial, sans-serif`;
        const captionY =
            titleY + headlineLines.length * titleFontSize * 1.08 + captionFontSize * 1.6;
        wrapText(ctx, caption, textMaxWidth).forEach((line, index) => {
            ctx.fillText(line, textX, captionY + index * captionFontSize * 1.4);
        });

        ctx.fillStyle = theme.accent;
        ctx.font = `700 ${Math.round(captionFontSize * 0.86)}px Arial, sans-serif`;
        ctx.fillText(
            "Static QR code - no tracking",
            safeMargin,
            preset.height - safeMargin,
        );

        currentPlatformDataUrl = canvas.toDataURL("image/png");
        platformPreviewImage.src = currentPlatformDataUrl;
        platformSizeLabel.textContent = `${preset.label} · ${preset.width} x ${preset.height}`;
        platformPreviewCard.classList.remove("hidden");
    }

    // 生成主函数
    async function generateQRCode() {
        const content = contentInput.value.trim();
        if (!content) {
            errorMessage.textContent = "Please enter some text or a valid URL.";
            errorMessage.classList.remove("hidden");
            return;
        }
        errorMessage.classList.add("hidden");

        const size = parseInt(sizeSelect.value, 10);
        const hasLogo = Boolean(uploadedLogoDataUrl || activePresetLogo !== "none");
        const level = (hasLogo ? "H" : levelSelect.value) as
            | "L"
            | "M"
            | "Q"
            | "H";
        const fgColor = fgColorInput.value;
        const bgColor = bgColorInput.value;

        try {
            const logoDataUrl =
                uploadedLogoDataUrl || createPresetLogoDataUrl(activePresetLogo);
            const canvas = await renderStyledQrCanvas(
                content,
                size,
                level,
                fgColor,
                bgColor,
                logoDataUrl,
            );
            const pngUrl = canvas.toDataURL("image/png");
            currentPngDataUrl = pngUrl;
            qrImage.src = pngUrl;

            currentSvgContent = await QRCode.toString(content, {
                type: "svg",
                width: size,
                margin: 4,
                errorCorrectionLevel: level,
                color: {
                    dark: fgColor,
                    light: bgColor,
                },
            });

            // 4. UI 切换
            previewPlaceholder.classList.add("hidden");
            qrContainer.classList.remove("hidden");
            actionButtons.classList.remove("hidden");
            advancedStyleNote.classList.remove("hidden");
            btnCopyUrl.classList.remove("hidden");
            await updatePlatformBackground();
        } catch (err: any) {
            console.error(err);
            errorMessage.textContent = `Error generating QR Code: ${err.message || err}`;
            errorMessage.classList.remove("hidden");
        }
    }

    // 按钮交互
    btnGenerate.addEventListener("click", generateQRCode);

    btnExample.addEventListener("click", () => {
        contentInput.value = "https://qrbarcodekit.com";
        generateQRCode();
    });

    btnReset.addEventListener("click", () => {
        contentInput.value = "";
        sizeSelect.value = "256";
        levelSelect.value = "M";
        fgColorInput.value = "#000000";
        fgColorText.value = "#000000";
        bgColorInput.value = "#ffffff";
        bgColorText.value = "#ffffff";
        framePhraseInput.value = "SCAN ME";
        frameColorInput.value = "#0f172a";
        activeFrameStyle = "none";
        activeModuleShape = "square";
        activeFinderStyle = "square";
        activePresetLogo = "none";
        const noFrameButton = document.querySelector<HTMLButtonElement>(
            '[data-frame="none"]',
        );
        const squareShapeButton = document.querySelector<HTMLButtonElement>(
            '[data-shape="square"]',
        );
        const squareFinderButton = document.querySelector<HTMLButtonElement>(
            '[data-finder="square"]',
        );
        const noLogoButton = document.querySelector<HTMLButtonElement>(
            '[data-logo="none"]',
        );
        if (noFrameButton) setActiveButton("frame-options", noFrameButton);
        if (squareShapeButton) {
            setActiveButton("module-shape-options", squareShapeButton);
        }
        if (squareFinderButton) {
            setActiveButton("finder-style-options", squareFinderButton);
        }
        if (noLogoButton) setActiveButton("preset-logo-options", noLogoButton);

        // Reset logo inputs
        qrLogoInput.value = "";
        uploadedLogoDataUrl = "";
        logoFilenameSpan.textContent = "No logo selected";
        btnClearLogo.classList.add("hidden");
        logoSizeSlider.value = "20";
        logoSizeValSpan.textContent = "20";
        logoBorderCheckbox.checked = true;
        platformPresetSelect.value = "none";
        platformThemeSelect.value = "blue";
        platformTitleInput.value = "Scan to open";
        platformCaptionInput.value = "Created with QR Barcode Tools";

        errorMessage.classList.add("hidden");

        // reset preview
        previewPlaceholder.classList.remove("hidden");
        qrContainer.classList.add("hidden");
        actionButtons.classList.add("hidden");
        advancedStyleNote.classList.add("hidden");
        btnCopyUrl.classList.add("hidden");
        qrImage.src = "";
        currentPngDataUrl = "";
        currentSvgContent = "";
        currentPlatformDataUrl = "";
        platformPreviewCard.classList.add("hidden");
        platformPreviewImage.src = "";
    });

    // 下载 PNG
    btnDownloadPng.addEventListener("click", () => {
        if (!currentPngDataUrl) return;
        const link = document.createElement("a");
        link.href = currentPngDataUrl;
        link.download = `qr-code-${Date.now()}.png`;
        document.body.appendChild(link);
        link.click();
        document.body.removeChild(link);
    });

    // 下载 SVG
    btnDownloadSvg.addEventListener("click", () => {
        if (!currentSvgContent) return;
        const blob = new Blob([currentSvgContent], {
            type: "image/svg+xml;charset=utf-8",
        });
        const blobUrl = URL.createObjectURL(blob);
        const link = document.createElement("a");
        link.href = blobUrl;
        link.download = `qr-code-${Date.now()}.svg`;
        document.body.appendChild(link);
        link.click();
        document.body.removeChild(link);
        URL.revokeObjectURL(blobUrl);
    });

    btnDownloadPlatform.addEventListener("click", () => {
        if (!currentPlatformDataUrl) return;
        const preset = platformPresetSelect.value || "platform";
        const link = document.createElement("a");
        link.href = currentPlatformDataUrl;
        link.download = `qr-code-${preset}-${Date.now()}.png`;
        document.body.appendChild(link);
        link.click();
        document.body.removeChild(link);
    });

    // 复制 Data URI
    btnCopyUrl.addEventListener("click", async () => {
        if (!currentPngDataUrl) return;
        try {
            await navigator.clipboard.writeText(currentPngDataUrl);
            const copyText = document.getElementById("copy-text");
            const copyIcon = document.getElementById("copy-icon");
            if (copyText && copyIcon) {
                copyText.textContent = "Copied!";
                setTimeout(() => {
                    copyText.textContent = "Copy Image Data URI";
                }, 2000);
            }
        } catch (err) {
            console.error("Failed to copy text: ", err);
        }
    });

    // 监听输入框的回车(Ctrl+Enter)也可以触发生成
    contentInput.addEventListener("keydown", (e) => {
        if (e.key === "Enter" && e.ctrlKey) {
            generateQRCode();
        }
    });
</script>
