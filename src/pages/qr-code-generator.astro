---
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "QR Code Generator - Create Free Static QR Codes Online";
const description =
    "Create a free static QR code for text, links, WiFi, and contact details in your browser. No sign-up, no upload, no tracking.";
---

<BaseLayout title={title} description={description}>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <!-- Breadcrumb -->
        <nav class="flex text-xs text-slate-500 mb-6" aria-label="Breadcrumb">
            <ol class="inline-flex items-center space-x-1 md:space-x-3">
                <li class="inline-flex items-center">
                    <a href="/" class="hover:text-brand-600">Home</a>
                </li>
                <li>
                    <div class="flex items-center">
                        <svg
                            class="w-3 h-3 text-slate-400 mx-1"
                            fill="currentColor"
                            viewBox="0 0 20 20"
                            ><path
                                fill-rule="evenodd"
                                d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z"
                                clip-rule="evenodd"></path></svg
                        >
                        <span class="text-slate-400" aria-current="page"
                            >QR Code Generator</span
                        >
                    </div>
                </li>
            </ol>
        </nav>

        <!-- H1 Header -->
        <div class="text-center md:text-left mb-10">
            <h1
                class="text-3xl md:text-4xl font-extrabold text-slate-900 tracking-tight"
            >
                Free Static <span class="text-gradient">QR Code Generator</span>
            </h1>
            <p class="text-slate-600 mt-2 max-w-2xl">
                Generate premium-quality, static QR codes instantly. Custom
                colors, sizes, and correction levels, 100% processed locally in
                your browser.
            </p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
            <!-- Left Column: Settings Form -->
            <div
                class="lg:col-span-7 bg-white rounded-2xl border border-slate-200/80 shadow-md p-6 md:p-8 space-y-6"
            >
                <div>
                    <div class="flex justify-between items-center mb-2">
                        <label
                            for="qr-content"
                            class="block text-sm font-bold text-slate-700"
                            >QR Code Content (Text or URL)</label
                        >
                        <button
                            id="btn-example"
                            class="text-xs font-semibold text-brand-600 hover:text-brand-700 transition-colors bg-brand-50 px-2 py-1 rounded"
                        >
                            Load Example
                        </button>
                    </div>
                    <textarea
                        id="qr-content"
                        rows="4"
                        class="w-full rounded-xl border border-slate-300 px-4 py-3 text-slate-800 placeholder-slate-400 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 focus:outline-none transition-all text-sm"
                        placeholder="Type your text or paste a URL here..."
                    ></textarea>
                    <p
                        id="error-message"
                        class="text-xs text-red-500 mt-1 hidden font-semibold"
                    >
                    </p>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <!-- Size -->
                    <div>
                        <label
                            for="qr-size"
                            class="block text-sm font-bold text-slate-700 mb-2"
                            >Size (pixels)</label
                        >
                        <select
                            id="qr-size"
                            class="w-full rounded-xl border border-slate-300 px-3 py-2 text-slate-700 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 focus:outline-none bg-white"
                        >
                            <option value="128">128 x 128</option>
                            <option value="256" selected>256 x 256</option>
                            <option value="512">512 x 512</option>
                            <option value="1024">1024 x 1024</option>
                        </select>
                    </div>

                    <!-- Error Correction -->
                    <div>
                        <label
                            for="qr-level"
                            class="block text-sm font-bold text-slate-700 mb-2"
                            >Error Correction Level</label
                        >
                        <select
                            id="qr-level"
                            class="w-full rounded-xl border border-slate-300 px-3 py-2 text-slate-700 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 focus:outline-none bg-white"
                        >
                            <option value="L">L (Low - 7% recovery)</option>
                            <option value="M" selected
                                >M (Medium - 15% recovery)</option
                            >
                            <option value="Q"
                                >Q (Quartile - 25% recovery)</option
                            >
                            <option value="H">H (High - 30% recovery)</option>
                        </select>
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <!-- Foreground Color -->
                    <div>
                        <label
                            for="qr-fg"
                            class="block text-sm font-bold text-slate-700 mb-2"
                            >Foreground Color</label
                        >
                        <div class="flex items-center space-x-3">
                            <input
                                type="color"
                                id="qr-fg"
                                value="#000000"
                                class="h-10 w-16 p-1 border border-slate-300 rounded-lg cursor-pointer bg-white"
                            />
                            <input
                                type="text"
                                id="qr-fg-text"
                                value="#000000"
                                class="w-full rounded-xl border border-slate-300 px-3 py-2 text-slate-700 text-sm focus:border-brand-500 focus:outline-none"
                            />
                        </div>
                    </div>

                    <!-- Background Color -->
                    <div>
                        <label
                            for="qr-bg"
                            class="block text-sm font-bold text-slate-700 mb-2"
                            >Background Color</label
                        >
                        <div class="flex items-center space-x-3">
                            <input
                                type="color"
                                id="qr-bg"
                                value="#ffffff"
                                class="h-10 w-16 p-1 border border-slate-300 rounded-lg cursor-pointer bg-white"
                            />
                            <input
                                type="text"
                                id="qr-bg-text"
                                value="#ffffff"
                                class="w-full rounded-xl border border-slate-300 px-3 py-2 text-slate-700 text-sm focus:border-brand-500 focus:outline-none"
                            />
                        </div>
                    </div>
                </div>

                <!-- Logo Upload Section -->
                <div class="pt-4 border-t border-slate-100 space-y-4">
                    <h3 class="text-sm font-bold text-slate-700">
                        Add Custom Logo (Optional)
                    </h3>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <!-- File upload -->
                        <div class="space-y-2">
                            <label
                                class="block text-xs font-semibold text-slate-500 uppercase tracking-wider"
                                >Upload Image</label
                            >
                            <div class="flex items-center space-x-3">
                                <label
                                    for="qr-logo"
                                    class="cursor-pointer inline-flex items-center space-x-2 bg-slate-100 hover:bg-slate-200 text-slate-700 font-semibold py-2 px-4 rounded-xl text-xs transition-colors border border-slate-300"
                                >
                                    <svg
                                        class="h-4 w-4 text-slate-500"
                                        fill="none"
                                        viewBox="0 0 24 24"
                                        stroke="currentColor"
                                        stroke-width="2"
                                    >
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"
                                        ></path>
                                    </svg>
                                    <span>Choose File</span>
                                </label>
                                <input
                                    type="file"
                                    id="qr-logo"
                                    accept="image/*"
                                    class="hidden"
                                />
                                <span
                                    id="logo-filename"
                                    class="text-xs text-slate-400 truncate max-w-[150px]"
                                    >No logo selected</span
                                >
                                <button
                                    id="btn-clear-logo"
                                    type="button"
                                    class="text-xs font-bold text-red-500 hover:text-red-600 hidden"
                                    >Remove</button
                                >
                            </div>
                        </div>

                        <!-- Logo Controls -->
                        <div class="space-y-3">
                            <div>
                                <label
                                    for="logo-size"
                                    class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1.5"
                                    >Logo Size (<span id="logo-size-val"
                                        >20</span
                                    >%)</label
                                >
                                <input
                                    type="range"
                                    id="logo-size"
                                    min="10"
                                    max="28"
                                    value="20"
                                    class="w-full h-2 bg-slate-200 rounded-lg appearance-none cursor-pointer accent-brand-500"
                                />
                            </div>
                            <div class="flex items-center">
                                <input
                                    type="checkbox"
                                    id="logo-border"
                                    checked
                                    class="h-4 w-4 rounded border-slate-300 text-brand-600 focus:ring-brand-200"
                                />
                                <label
                                    for="logo-border"
                                    class="ml-2 text-xs font-semibold text-slate-700 select-none"
                                    >Draw clear background border</label
                                >
                            </div>
                        </div>
                    </div>
                    <p class="text-[11px] text-slate-400 italic">
                        <strong>Tip:</strong> If you upload a logo, the generator
                        will automatically switch the <strong
                            >Error Correction Level to H (30%)</strong
                        >. This ensures the QR code is still readable with the
                        logo in the center.
                    </p>
                </div>

                <div class="flex space-x-3 pt-2">
                    <button
                        id="btn-generate"
                        class="brand-gradient hover:brand-gradient-hover text-white font-semibold px-6 py-3 rounded-xl shadow-md transition-colors flex-grow"
                    >
                        Generate QR Code
                    </button>
                    <button
                        id="btn-reset"
                        class="border border-slate-300 hover:border-slate-400 hover:bg-slate-50 text-slate-600 px-4 py-3 rounded-xl transition-colors"
                    >
                        Reset
                    </button>
                </div>
            </div>

            <!-- Right Column: Live Preview Area -->
            <div class="lg:col-span-5 space-y-6">
                <div
                    class="bg-white rounded-2xl border border-slate-200/80 shadow-md p-6 flex flex-col items-center justify-center text-center"
                >
                    <h2 class="text-lg font-bold text-slate-900 mb-4">
                        Preview
                    </h2>

                    <!-- Code Wrapper -->
                    <div
                        class="p-6 bg-slate-50 border border-slate-150 rounded-xl relative flex items-center justify-center min-h-[260px] min-w-[260px]"
                    >
                        <div
                            id="preview-placeholder"
                            class="text-slate-400 text-sm flex flex-col items-center"
                        >
                            <svg
                                class="h-12 w-12 text-slate-300 mb-2 animate-pulse"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="1.5"
                            >
                                <rect x="3" y="3" width="18" height="18" rx="2"
                                ></rect>
                                <rect x="7" y="7" width="3" height="3"></rect>
                                <rect x="14" y="7" width="3" height="3"></rect>
                                <rect x="7" y="14" width="3" height="3"></rect>
                            </svg>
                            <span>Waiting for input content</span>
                        </div>

                        <div id="qr-container" class="hidden">
                            <img
                                id="qr-image"
                                src=""
                                alt="Generated QR Code"
                                class="max-w-full h-auto mx-auto border shadow-sm rounded bg-white"
                            />
                        </div>
                    </div>

                    <div
                        id="action-buttons"
                        class="w-full grid grid-cols-2 gap-3 mt-6 hidden"
                    >
                        <button
                            id="btn-download-png"
                            class="flex items-center justify-center space-x-2 bg-slate-900 hover:bg-slate-800 text-white font-semibold py-2.5 px-4 rounded-xl shadow-sm transition-colors text-sm"
                        >
                            <svg
                                class="h-4 w-4"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                                stroke-width="2"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"
                                ></path>
                            </svg>
                            <span>Download PNG</span>
                        </button>

                        <button
                            id="btn-download-svg"
                            class="flex items-center justify-center space-x-2 border border-slate-300 hover:border-slate-400 hover:bg-slate-50 text-slate-700 font-semibold py-2.5 px-4 rounded-xl transition-colors text-sm"
                        >
                            <svg
                                class="h-4 w-4"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                                stroke-width="2"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"
                                ></path>
                            </svg>
                            <span>Download SVG</span>
                        </button>
                    </div>

                    <button
                        id="btn-copy-url"
                        class="w-full mt-3 hidden flex items-center justify-center space-x-2 text-xs font-semibold text-brand-600 bg-brand-50 hover:bg-brand-100 py-2 rounded-lg transition-colors"
                    >
                        <svg
                            class="h-4 w-4"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                            stroke-width="2"
                            id="copy-icon"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2"
                            ></path>
                        </svg>
                        <span id="copy-text">Copy Image Data URI</span>
                    </button>
                </div>

                <!-- Warning / Notes card -->
                <div
                    class="bg-blue-50 border border-blue-100 rounded-2xl p-5 space-y-3"
                >
                    <h3
                        class="text-sm font-bold text-blue-900 flex items-center"
                    >
                        <svg
                            class="h-5 w-5 mr-1.5 text-blue-600"
                            viewBox="0 0 20 20"
                            fill="currentColor"
                        >
                            <path
                                fill-rule="evenodd"
                                d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z"
                                clip-rule="evenodd"></path>
                        </svg>
                        Important QR Code Notes
                    </h3>
                    <ul
                        class="list-disc list-inside text-xs text-blue-800 space-y-1.5 leading-relaxed"
                    >
                        <li>
                            <strong>Static QR Code:</strong> This creates a static
                            QR code. The information is coded directly into the dots.
                        </li>
                        <li>
                            <strong>Non-editable:</strong> The QR code content cannot
                            be edited or updated after download. Changing the URL
                            means creating a new QR code.
                        </li>
                        <li>
                            <strong>No Tracking:</strong> This tool is 100% private.
                            It does not provide scan tracking, custom short links,
                            or click analytics.
                        </li>
                    </ul>
                </div>
            </div>
        </div>

        <!-- Instructions / Content Section -->
        <section
            class="mt-16 bg-white rounded-2xl border border-slate-200/80 p-8 md:p-10 space-y-8"
        >
            <div>
                <h2 class="text-2xl font-bold text-slate-900 mb-4">
                    What is a Static QR Code?
                </h2>
                <p class="text-slate-600 leading-relaxed text-sm">
                    A QR (Quick Response) code is a type of matrix barcode that
                    stores information as a series of pixels in a square grid.
                    In a <strong>Static QR Code</strong>, your target
                    data—whether it is a website link, a raw paragraph of text,
                    or a contact details payload—is directly embedded into the
                    graphical matrix.
                </p>
                <p class="text-slate-600 leading-relaxed text-sm mt-3">
                    Because the content is physical, the pixel density of the QR
                    code increases as you add more text. Static codes are
                    incredibly reliable and fast, because any scanner can read
                    them offline without relying on dynamic link servers.
                </p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <div>
                    <h3 class="text-lg font-bold text-slate-900 mb-3">
                        Best Practices for Custom Colors
                    </h3>
                    <p class="text-slate-600 leading-relaxed text-sm">
                        To ensure your custom QR code scans easily by all
                        smartphones, maintain a <strong>high contrast</strong> between
                        the foreground and background colors. Always use a dark color
                        for the foreground and a light color for the background. Light
                        foregrounds on dark backgrounds (inverted QR codes) can fail
                        to scan on some older scanning hardware and default camera
                        apps.
                    </p>
                </div>
                <div>
                    <h3 class="text-lg font-bold text-slate-900 mb-3">
                        What is Error Correction Level?
                    </h3>
                    <p class="text-slate-600 leading-relaxed text-sm">
                        QR codes have an inherent error-correction capability
                        (built using Reed-Solomon codes) which allows them to
                        scan correctly even if the image is partially damaged,
                        dirty, or obscured.
                        <br />- <strong>Level L:</strong> Recovers up to 7% of data
                        (best for tiny/clean codes).
                        <br />- <strong>Level M:</strong> Recovers up to 15% (standard
                        default).
                        <br />- <strong>Level Q:</strong> Recovers up to 25%.
                        <br />- <strong>Level H:</strong> Recovers up to 30% (best
                        if you want to place a custom logo in the middle).
                    </p>
                </div>
            </div>

            <!-- Specialty Links -->
            <div class="pt-6 border-t border-slate-100">
                <h3
                    class="text-sm font-semibold text-slate-400 uppercase tracking-wider mb-4"
                >
                    Need specific QR formats?
                </h3>
                <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
                    <a
                        href="/wifi-qr-code-generator/"
                        class="flex items-center space-x-2 text-sm font-semibold text-brand-600 hover:text-brand-700 bg-brand-50/50 hover:bg-brand-50 p-3 rounded-xl transition-colors"
                    >
                        <span>🌐 WiFi QR Code Generator</span>
                    </a>
                    <a
                        href="/url-qr-code-generator/"
                        class="flex items-center space-x-2 text-sm font-semibold text-brand-600 hover:text-brand-700 bg-brand-50/50 hover:bg-brand-50 p-3 rounded-xl transition-colors"
                    >
                        <span>🔗 URL QR Code Generator</span>
                    </a>
                    <a
                        href="/vcard-qr-code-generator/"
                        class="flex items-center space-x-2 text-sm font-semibold text-brand-600 hover:text-brand-700 bg-brand-50/50 hover:bg-brand-50 p-3 rounded-xl transition-colors"
                    >
                        <span>📇 vCard QR Code Generator</span>
                    </a>
                </div>
            </div>
        </section>
    </div>
</BaseLayout>

<script>
    import QRCode from "qrcode";

    const contentInput = document.getElementById(
        "qr-content",
    ) as HTMLTextAreaElement;
    const sizeSelect = document.getElementById("qr-size") as HTMLSelectElement;
    const levelSelect = document.getElementById(
        "qr-level",
    ) as HTMLSelectElement;
    const fgColorInput = document.getElementById("qr-fg") as HTMLInputElement;
    const fgColorText = document.getElementById(
        "qr-fg-text",
    ) as HTMLInputElement;
    const bgColorInput = document.getElementById("qr-bg") as HTMLInputElement;
    const bgColorText = document.getElementById(
        "qr-bg-text",
    ) as HTMLInputElement;

    // Logo Upload elements
    const qrLogoInput = document.getElementById("qr-logo") as HTMLInputElement;
    const logoFilenameSpan = document.getElementById(
        "logo-filename",
    ) as HTMLSpanElement;
    const btnClearLogo = document.getElementById(
        "btn-clear-logo",
    ) as HTMLButtonElement;
    const logoSizeSlider = document.getElementById(
        "logo-size",
    ) as HTMLInputElement;
    const logoSizeValSpan = document.getElementById(
        "logo-size-val",
    ) as HTMLSpanElement;
    const logoBorderCheckbox = document.getElementById(
        "logo-border",
    ) as HTMLInputElement;

    const btnGenerate = document.getElementById(
        "btn-generate",
    ) as HTMLButtonElement;
    const btnReset = document.getElementById("btn-reset") as HTMLButtonElement;
    const btnExample = document.getElementById(
        "btn-example",
    ) as HTMLButtonElement;

    const previewPlaceholder = document.getElementById(
        "preview-placeholder",
    ) as HTMLDivElement;
    const qrContainer = document.getElementById(
        "qr-container",
    ) as HTMLDivElement;
    const qrImage = document.getElementById("qr-image") as HTMLImageElement;
    const actionButtons = document.getElementById(
        "action-buttons",
    ) as HTMLDivElement;
    const btnCopyUrl = document.getElementById(
        "btn-copy-url",
    ) as HTMLButtonElement;
    const btnDownloadPng = document.getElementById(
        "btn-download-png",
    ) as HTMLButtonElement;
    const btnDownloadSvg = document.getElementById(
        "btn-download-svg",
    ) as HTMLButtonElement;
    const errorMessage = document.getElementById(
        "error-message",
    ) as HTMLParagraphElement;

    let currentPngDataUrl = "";
    let currentSvgContent = "";
    let uploadedLogoDataUrl = "";

    // 同步颜色输入框
    fgColorInput.addEventListener("input", (e) => {
        fgColorText.value = (e.target as HTMLInputElement).value;
    });
    fgColorText.addEventListener("change", (e) => {
        const val = (e.target as HTMLInputElement).value;
        if (/^#[0-9A-F]{6}$/i.test(val)) {
            fgColorInput.value = val;
        }
    });
    bgColorInput.addEventListener("input", (e) => {
        bgColorText.value = (e.target as HTMLInputElement).value;
    });
    bgColorText.addEventListener("change", (e) => {
        const val = (e.target as HTMLInputElement).value;
        if (/^#[0-9A-F]{6}$/i.test(val)) {
            bgColorInput.value = val;
        }
    });

    // 监听 Logo 上传
    qrLogoInput.addEventListener("change", (e) => {
        const file = (e.target as HTMLInputElement).files?.[0];
        if (file) {
            logoFilenameSpan.textContent = file.name;
            btnClearLogo.classList.remove("hidden");
            const reader = new FileReader();
            reader.onload = (event) => {
                uploadedLogoDataUrl = event.target?.result as string;
                // Logo 推荐使用 H 级别纠错
                levelSelect.value = "H";
                generateQRCode();
            };
            reader.readAsDataURL(file);
        }
    });

    // 清空 Logo
    btnClearLogo.addEventListener("click", () => {
        qrLogoInput.value = "";
        uploadedLogoDataUrl = "";
        logoFilenameSpan.textContent = "No logo selected";
        btnClearLogo.classList.add("hidden");
        generateQRCode();
    });

    // 调节尺寸滑块
    logoSizeSlider.addEventListener("input", (e) => {
        const val = (e.target as HTMLInputElement).value;
        logoSizeValSpan.textContent = val;
    });
    logoSizeSlider.addEventListener("change", () => {
        generateQRCode();
    });
    logoBorderCheckbox.addEventListener("change", () => {
        generateQRCode();
    });

    // 生成主函数
    async function generateQRCode() {
        const content = contentInput.value.trim();
        if (!content) {
            errorMessage.textContent = "Please enter some text or a valid URL.";
            errorMessage.classList.remove("hidden");
            return;
        }
        errorMessage.classList.add("hidden");

        const size = parseInt(sizeSelect.value, 10);
        const level = (uploadedLogoDataUrl ? "H" : levelSelect.value) as
            | "L"
            | "M"
            | "Q"
            | "H";
        const fgColor = fgColorInput.value;
        const bgColor = bgColorInput.value;

        try {
            // 1. 生成基础/带 Logo 的 Canvas
            const canvas = document.createElement("canvas");
            await QRCode.toCanvas(canvas, content, {
                width: size,
                margin: 2,
                errorCorrectionLevel: level,
                color: {
                    dark: fgColor,
                    light: bgColor,
                },
            });

            // 2. 如果有 Logo，则绘制到 Canvas 中央
            if (uploadedLogoDataUrl) {
                await new Promise<void>((resolve, reject) => {
                    const img = new Image();
                    img.crossOrigin = "anonymous";
                    img.onload = () => {
                        const ctx = canvas.getContext("2d");
                        if (ctx) {
                            const logoPercent =
                                parseInt(logoSizeSlider.value, 10) / 100;
                            const logoSize = size * logoPercent;
                            const logoX = (size - logoSize) / 2;
                            const logoY = (size - logoSize) / 2;

                            if (logoBorderCheckbox.checked) {
                                // 在中央绘制白底矩形/圆角矩形
                                const padding = logoSize * 0.15;
                                ctx.fillStyle = bgColor;
                                ctx.beginPath();
                                // 圆角矩形支持
                                if (typeof ctx.roundRect === "function") {
                                    ctx.roundRect(
                                        logoX - padding,
                                        logoY - padding,
                                        logoSize + padding * 2,
                                        logoSize + padding * 2,
                                        logoSize * 0.15,
                                    );
                                } else {
                                    ctx.rect(
                                        logoX - padding,
                                        logoY - padding,
                                        logoSize + padding * 2,
                                        logoSize + padding * 2,
                                    );
                                }
                                ctx.fill();
                            }

                            // 绘制 logo 图像
                            ctx.drawImage(
                                img,
                                logoX,
                                logoY,
                                logoSize,
                                logoSize,
                            );
                        }
                        resolve();
                    };
                    img.onerror = (err) => reject(err);
                    img.src = uploadedLogoDataUrl;
                });
            }

            // 输出 PNG dataURL
            const pngUrl = canvas.toDataURL("image/png");
            currentPngDataUrl = pngUrl;
            qrImage.src = pngUrl;

            // 3. 生成 SVG 并合并 Logo 嵌入
            let svgString = await QRCode.toString(content, {
                type: "svg",
                width: size,
                margin: 2,
                errorCorrectionLevel: level,
                color: {
                    dark: fgColor,
                    light: bgColor,
                },
            });

            if (uploadedLogoDataUrl) {
                const parser = new DOMParser();
                const doc = parser.parseFromString(svgString, "image/svg+xml");
                const svgEl = doc.querySelector("svg");
                if (svgEl) {
                    const logoPercent =
                        parseInt(logoSizeSlider.value, 10) / 100;
                    const logoSize = size * logoPercent;
                    const logoX = (size - logoSize) / 2;
                    const logoY = (size - logoSize) / 2;

                    if (logoBorderCheckbox.checked) {
                        const padding = logoSize * 0.15;
                        const rect = doc.createElementNS(
                            "http://www.w3.org/2000/svg",
                            "rect",
                        );
                        rect.setAttribute("x", (logoX - padding).toString());
                        rect.setAttribute("y", (logoY - padding).toString());
                        rect.setAttribute(
                            "width",
                            (logoSize + padding * 2).toString(),
                        );
                        rect.setAttribute(
                            "height",
                            (logoSize + padding * 2).toString(),
                        );
                        rect.setAttribute("fill", bgColor);
                        rect.setAttribute("rx", (logoSize * 0.15).toString());
                        rect.setAttribute("ry", (logoSize * 0.15).toString());
                        svgEl.appendChild(rect);
                    }

                    const image = doc.createElementNS(
                        "http://www.w3.org/2000/svg",
                        "image",
                    );
                    image.setAttribute("href", uploadedLogoDataUrl);
                    image.setAttribute("x", logoX.toString());
                    image.setAttribute("y", logoY.toString());
                    image.setAttribute("width", logoSize.toString());
                    image.setAttribute("height", logoSize.toString());
                    svgEl.appendChild(image);

                    const serializer = new XMLSerializer();
                    svgString = serializer.serializeToString(doc);
                }
            }
            currentSvgContent = svgString;

            // 4. UI 切换
            previewPlaceholder.classList.add("hidden");
            qrContainer.classList.remove("hidden");
            actionButtons.classList.remove("hidden");
            btnCopyUrl.classList.remove("hidden");
        } catch (err: any) {
            console.error(err);
            errorMessage.textContent = `Error generating QR Code: ${err.message || err}`;
            errorMessage.classList.remove("hidden");
        }
    }

    // 按钮交互
    btnGenerate.addEventListener("click", generateQRCode);

    btnExample.addEventListener("click", () => {
        contentInput.value = "https://qrbarcodetools.com";
        generateQRCode();
    });

    btnReset.addEventListener("click", () => {
        contentInput.value = "";
        sizeSelect.value = "256";
        levelSelect.value = "M";
        fgColorInput.value = "#000000";
        fgColorText.value = "#000000";
        bgColorInput.value = "#ffffff";
        bgColorText.value = "#ffffff";

        // Reset logo inputs
        qrLogoInput.value = "";
        uploadedLogoDataUrl = "";
        logoFilenameSpan.textContent = "No logo selected";
        btnClearLogo.classList.add("hidden");
        logoSizeSlider.value = "20";
        logoSizeValSpan.textContent = "20";
        logoBorderCheckbox.checked = true;

        errorMessage.classList.add("hidden");

        // reset preview
        previewPlaceholder.classList.remove("hidden");
        qrContainer.classList.add("hidden");
        actionButtons.classList.add("hidden");
        btnCopyUrl.classList.add("hidden");
        qrImage.src = "";
        currentPngDataUrl = "";
        currentSvgContent = "";
    });

    // 下载 PNG
    btnDownloadPng.addEventListener("click", () => {
        if (!currentPngDataUrl) return;
        const link = document.createElement("a");
        link.href = currentPngDataUrl;
        link.download = `qr-code-${Date.now()}.png`;
        document.body.appendChild(link);
        link.click();
        document.body.removeChild(link);
    });

    // 下载 SVG
    btnDownloadSvg.addEventListener("click", () => {
        if (!currentSvgContent) return;
        const blob = new Blob([currentSvgContent], {
            type: "image/svg+xml;charset=utf-8",
        });
        const blobUrl = URL.createObjectURL(blob);
        const link = document.createElement("a");
        link.href = blobUrl;
        link.download = `qr-code-${Date.now()}.svg`;
        document.body.appendChild(link);
        link.click();
        document.body.removeChild(link);
        URL.revokeObjectURL(blobUrl);
    });

    // 复制 Data URI
    btnCopyUrl.addEventListener("click", async () => {
        if (!currentPngDataUrl) return;
        try {
            await navigator.clipboard.writeText(currentPngDataUrl);
            const copyText = document.getElementById("copy-text");
            const copyIcon = document.getElementById("copy-icon");
            if (copyText && copyIcon) {
                copyText.textContent = "Copied!";
                setTimeout(() => {
                    copyText.textContent = "Copy Image Data URI";
                }, 2000);
            }
        } catch (err) {
            console.error("Failed to copy text: ", err);
        }
    });

    // 监听输入框的回车(Ctrl+Enter)也可以触发生成
    contentInput.addEventListener("keydown", (e) => {
        if (e.key === "Enter" && e.ctrlKey) {
            generateQRCode();
        }
    });
</script>
