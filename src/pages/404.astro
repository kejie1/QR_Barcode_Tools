---
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "Page Not Found - 404 | QR Barcode Tools";
const description =
    "Sorry, we couldn't find the page you were looking for. Visit our homepage to access our free QR code and barcode generators.";
---

<BaseLayout title={title} description={description}>
    <div class="max-w-xl mx-auto px-4 py-20 text-center space-y-6">
        <!-- Big Icon -->
        <div
            class="inline-flex items-center justify-center h-24 w-24 rounded-full bg-brand-50 text-brand-600 animate-bounce"
        >
            <svg
                class="h-12 w-12"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"
                ></path>
            </svg>
        </div>

        <!-- Error Codes -->
        <div class="space-y-2">
            <h1 class="text-6xl font-extrabold text-slate-900 tracking-tight">
                404
            </h1>
            <h2 class="text-2xl font-bold text-slate-800">Page Not Found</h2>
            <p class="text-slate-500 text-sm max-w-sm mx-auto leading-relaxed">
                We can't seem to find the page or tool you're looking for. It
                may have been moved, renamed, or is temporarily unavailable.
            </p>
        </div>

        <!-- Actions -->
        <div
            class="flex flex-col sm:flex-row items-center justify-center space-y-3 sm:space-y-0 sm:space-x-3 pt-4"
        >
            <a
                href="/"
                class="brand-gradient hover:brand-gradient-hover text-white font-bold px-6 py-3 rounded-xl shadow-md transition-colors w-full sm:w-auto text-sm"
            >
                Go Back Home
            </a>
            <a
                href="/qr-code-generator/"
                class="bg-white border border-slate-300 hover:border-slate-400 text-slate-700 font-bold px-6 py-3 rounded-xl transition-colors w-full sm:w-auto text-sm"
            >
                Use QR Generator
            </a>
        </div>
    </div>
</BaseLayout>
