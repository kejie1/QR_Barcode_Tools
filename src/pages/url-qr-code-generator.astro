---
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "URL QR Code Generator - Create Free Website Link QR Codes";
const description =
    "Easily turn website URLs, articles, or online content into a fast-loading static QR code. Completely free with infinite scans and zero server tracking.";
---

<BaseLayout title={title} description={description}>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <!-- Breadcrumb -->
        <nav class="flex text-xs text-slate-500 mb-6" aria-label="Breadcrumb">
            <ol class="inline-flex items-center space-x-1 md:space-x-3">
                <li class="inline-flex items-center">
                    <a href="/" class="hover:text-brand-600">Home</a>
                </li>
                <li>
                    <div class="flex items-center">
                        <svg
                            class="w-3 h-3 text-slate-400 mx-1"
                            fill="currentColor"
                            viewBox="0 0 20 20"
                            ><path
                                fill-rule="evenodd"
                                d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z"
                                clip-rule="evenodd"></path></svg
                        >
                        <span class="text-slate-400" aria-current="page"
                            >URL QR Code Generator</span
                        >
                    </div>
                </li>
            </ol>
        </nav>

        <!-- Header -->
        <div class="text-center md:text-left mb-10">
            <h1
                class="text-3xl md:text-4xl font-extrabold text-slate-900 tracking-tight"
            >
                Free <span class="text-gradient">URL QR Code Generator</span>
            </h1>
            <p class="text-slate-600 mt-2 max-w-2xl">
                Convert any website link, landing page, social profile, or
                document URL into a permanent QR code. High resolution, instant
                download, and standard format compliant.
            </p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
            <!-- Left Column: Settings Form -->
            <div
                class="lg:col-span-7 bg-white rounded-2xl border border-slate-200/80 shadow-md p-6 md:p-8 space-y-6"
            >
                <div>
                    <label
                        for="url-input"
                        class="block text-sm font-bold text-slate-700 mb-2"
                        >Website URL (Link)</label
                    >
                    <div
                        class="flex rounded-xl shadow-sm border border-slate-300 focus-within:border-brand-500 focus-within:ring-2 focus-within:ring-brand-200 focus-within:ring-offset-0 overflow-hidden transition-all bg-white"
                    >
                        <span
                            class="inline-flex items-center px-4 rounded-l-md border-r border-slate-200 bg-slate-50 text-slate-400 text-sm select-none font-semibold"
                        >
                            HTTPS://
                        </span>
                        <input
                            type="text"
                            id="url-input"
                            class="flex-1 block w-full px-4 py-3 text-slate-800 placeholder-slate-400 border-0 focus:ring-0 focus:outline-none text-sm"
                            placeholder="www.example.com/page"
                        />
                    </div>
                    <p class="text-xs text-slate-400 mt-1.5 font-medium">
                        Type your domain or copy/paste the entire URL. We
                        automatically ensure valid formatting.
                    </p>
                </div>

                <div
                    class="grid grid-cols-1 md:grid-cols-2 gap-6 pt-2 border-t border-slate-100"
                >
                    <div>
                        <label
                            for="qr-fg"
                            class="block text-sm font-bold text-slate-700 mb-2"
                            >QR Color (Dark)</label
                        >
                        <input
                            type="color"
                            id="qr-fg"
                            value="#000000"
                            class="h-10 w-full p-1 border border-slate-300 rounded-xl cursor-pointer bg-white"
                        />
                    </div>
                    <div>
                        <label
                            for="qr-bg"
                            class="block text-sm font-bold text-slate-700 mb-2"
                            >Background Color (Light)</label
                        >
                        <input
                            type="color"
                            id="qr-bg"
                            value="#ffffff"
                            class="h-10 w-full p-1 border border-slate-300 rounded-xl cursor-pointer bg-white"
                        />
                    </div>
                </div>

                <div class="flex space-x-3 pt-2">
                    <button
                        id="btn-generate"
                        class="brand-gradient hover:brand-gradient-hover text-white font-semibold px-6 py-3 rounded-xl shadow-md transition-colors flex-grow"
                    >
                        Generate Link QR Code
                    </button>
                    <button
                        id="btn-reset"
                        class="border border-slate-300 hover:border-slate-400 hover:bg-slate-50 text-slate-600 px-4 py-3 rounded-xl transition-colors"
                    >
                        Reset
                    </button>
                </div>
            </div>

            <!-- Right Column: Live Preview Area -->
            <div class="lg:col-span-5 space-y-6">
                <div
                    class="bg-white rounded-2xl border border-slate-200/80 shadow-md p-6 flex flex-col items-center justify-center text-center"
                >
                    <h2 class="text-lg font-bold text-slate-900 mb-4">
                        Preview
                    </h2>

                    <div
                        class="p-6 bg-slate-50 border border-slate-150 rounded-xl relative flex items-center justify-center min-h-[260px] min-w-[260px]"
                    >
                        <div
                            id="preview-placeholder"
                            class="text-slate-400 text-sm flex flex-col items-center"
                        >
                            <svg
                                class="h-12 w-12 text-slate-300 mb-2 animate-pulse"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="1.5"
                            >
                                <rect x="3" y="3" width="18" height="18" rx="2"
                                ></rect>
                                <path
                                    d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101"
                                ></path>
                            </svg>
                            <span>Enter a URL to generate code</span>
                        </div>

                        <div id="qr-container" class="hidden">
                            <img
                                id="qr-image"
                                src=""
                                alt="URL QR Code"
                                class="max-w-full h-auto mx-auto border shadow-sm rounded bg-white"
                            />
                        </div>
                    </div>

                    <div
                        id="action-buttons"
                        class="w-full grid grid-cols-2 gap-3 mt-6 hidden"
                    >
                        <button
                            id="btn-download-png"
                            class="flex items-center justify-center space-x-2 bg-slate-900 hover:bg-slate-800 text-white font-semibold py-2.5 px-4 rounded-xl shadow-sm transition-colors text-sm"
                        >
                            <svg
                                class="h-4 w-4"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                                stroke-width="2"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"
                                ></path>
                            </svg>
                            <span>Download PNG</span>
                        </button>

                        <button
                            id="btn-download-svg"
                            class="flex items-center justify-center space-x-2 border border-slate-300 hover:border-slate-400 hover:bg-slate-50 text-slate-700 font-semibold py-2.5 px-4 rounded-xl transition-colors text-sm"
                        >
                            <svg
                                class="h-4 w-4"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                                stroke-width="2"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"
                                ></path>
                            </svg>
                            <span>Download SVG</span>
                        </button>
                    </div>
                </div>

                <!-- Warning / Shortener warning -->
                <div
                    class="bg-amber-50 border border-amber-100 rounded-2xl p-5 space-y-3"
                >
                    <h3
                        class="text-sm font-bold text-amber-950 flex items-center"
                    >
                        <svg
                            class="h-5 w-5 mr-1.5 text-amber-700"
                            viewBox="0 0 20 20"
                            fill="currentColor"
                        >
                            <path
                                fill-rule="evenodd"
                                d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z"
                                clip-rule="evenodd"></path>
                        </svg>
                        URL QR Code Policy
                    </h3>
                    <ul
                        class="list-disc list-inside text-xs text-amber-900 space-y-1.5 leading-relaxed"
                    >
                        <li>
                            <strong>Not a URL Shortener:</strong> This encodes the
                            literal, complete text of the URL directly. We do not
                            provide intermediate redirect links.
                        </li>
                        <li>
                            <strong>No Tracking:</strong> Scans cannot be tracked
                            or analyzed. No dynamic statistical charts are generated.
                        </li>
                        <li>
                            <strong>Permanent Design:</strong> If the destination
                            website changes in the future, this static code cannot
                            redirect to the new site. You will need to generate a
                            new QR code.
                        </li>
                    </ul>
                </div>
            </div>
        </div>

        <!-- Instructions / Content Section -->
        <section
            class="mt-16 bg-white rounded-2xl border border-slate-200/80 p-8 md:p-10 space-y-8"
        >
            <div>
                <h2 class="text-2xl font-bold text-slate-900 mb-4">
                    Why Use Website Link QR Codes?
                </h2>
                <p class="text-slate-600 leading-relaxed text-sm">
                    A Link QR code is the most popular type of barcode scanned
                    today. It allows users to wave their smartphones to view
                    digital menus, access support portals, join events, or land
                    directly onto social media networks instantly without
                    manually typing long web addresses.
                </p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <div>
                    <h3 class="text-lg font-bold text-slate-900 mb-3">
                        Does HTTPS matter?
                    </h3>
                    <p class="text-slate-600 leading-relaxed text-sm">
                        Yes. Modern iOS and Android camera systems rely on the
                        full protocol declaration to recognize that the QR code
                        points to a digital webpage. If a code only contains
                        "example.com" without prefixing, some phones may
                        interpret it as raw search text rather than opening a
                        browser immediately. Our tool ensures a seamless
                        protocol is prefix-formatted.
                    </p>
                </div>
                <div>
                    <h3 class="text-lg font-bold text-slate-900 mb-3">
                        Maximizing Scan Speed
                    </h3>
                    <p class="text-slate-600 leading-relaxed text-sm">
                        Keep your URLs as short as possible. Longer URLs require
                        more data bits, which makes the QR code pixel grid
                        tighter and harder for low-end phone cameras to read
                        from a distance or in poor lighting.
                    </p>
                </div>
            </div>
        </section>
    </div>
</BaseLayout>

<script>
    import QRCode from "qrcode";

    const urlInput = document.getElementById("url-input") as HTMLInputElement;
    const fgColorInput = document.getElementById("qr-fg") as HTMLInputElement;
    const bgColorInput = document.getElementById("qr-bg") as HTMLInputElement;

    const btnGenerate = document.getElementById(
        "btn-generate",
    ) as HTMLButtonElement;
    const btnReset = document.getElementById("btn-reset") as HTMLButtonElement;

    const previewPlaceholder = document.getElementById(
        "preview-placeholder",
    ) as HTMLDivElement;
    const qrContainer = document.getElementById(
        "qr-container",
    ) as HTMLDivElement;
    const qrImage = document.getElementById("qr-image") as HTMLImageElement;
    const actionButtons = document.getElementById(
        "action-buttons",
    ) as HTMLDivElement;
    const btnDownloadPng = document.getElementById(
        "btn-download-png",
    ) as HTMLButtonElement;
    const btnDownloadSvg = document.getElementById(
        "btn-download-svg",
    ) as HTMLButtonElement;

    let currentPngDataUrl = "";
    let currentSvgContent = "";

    function generateURLCode() {
        let rawUrl = urlInput.value.trim();
        if (!rawUrl) {
            alert("Please enter a website link URL.");
            return;
        }

        // Auto prepend HTTPS if not already present
        let finalUrl = rawUrl;
        if (!/^https?:\/\//i.test(rawUrl)) {
            finalUrl = "https://" + rawUrl;
        }

        const fgColor = fgColorInput.value;
        const bgColor = bgColorInput.value;

        try {
            QRCode.toDataURL(
                finalUrl,
                {
                    width: 380,
                    margin: 2,
                    errorCorrectionLevel: "M",
                    color: {
                        dark: fgColor,
                        light: bgColor,
                    },
                },
                (err, url) => {
                    if (err) throw err;
                    currentPngDataUrl = url;
                    qrImage.src = url;
                },
            );

            QRCode.toString(
                finalUrl,
                {
                    type: "svg",
                    width: 380,
                    margin: 2,
                    errorCorrectionLevel: "M",
                    color: {
                        dark: fgColor,
                        light: bgColor,
                    },
                },
                (err, svgString) => {
                    if (err) throw err;
                    currentSvgContent = svgString;
                },
            );

            previewPlaceholder.classList.add("hidden");
            qrContainer.classList.remove("hidden");
            actionButtons.classList.remove("hidden");
        } catch (e) {
            console.error(e);
            alert("Failed to generate URL QR Code.");
        }
    }

    btnGenerate.addEventListener("click", generateURLCode);

    btnReset.addEventListener("click", () => {
        urlInput.value = "";
        fgColorInput.value = "#000000";
        bgColorInput.value = "#ffffff";

        previewPlaceholder.classList.remove("hidden");
        qrContainer.classList.add("hidden");
        actionButtons.classList.add("hidden");
        qrImage.src = "";
        currentPngDataUrl = "";
        currentSvgContent = "";
    });

    btnDownloadPng.addEventListener("click", () => {
        if (!currentPngDataUrl) return;
        const link = document.createElement("a");
        link.href = currentPngDataUrl;
        link.download = `url-qr-${Date.now()}.png`;
        document.body.appendChild(link);
        link.click();
        document.body.removeChild(link);
    });

    btnDownloadSvg.addEventListener("click", () => {
        if (!currentSvgContent) return;
        const blob = new Blob([currentSvgContent], {
            type: "image/svg+xml;charset=utf-8",
        });
        const blobUrl = URL.createObjectURL(blob);
        const link = document.createElement("a");
        link.href = blobUrl;
        link.download = `url-qr-${Date.now()}.svg`;
        document.body.appendChild(link);
        link.click();
        document.body.removeChild(link);
        URL.revokeObjectURL(blobUrl);
    });

    // Check trigger on Enter
    urlInput.addEventListener("keydown", (e) => {
        if (e.key === "Enter") {
            generateURLCode();
        }
    });
</script>
