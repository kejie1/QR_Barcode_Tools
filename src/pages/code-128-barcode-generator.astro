---
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "Code 128 Barcode Generator - Free Online Asset Tagging Tool";
const description =
    "Create custom Code 128 barcode graphics instantly. Perfect for warehouse tags, asset tagging, inventory labels, and internal manufacturing control.";
---

<BaseLayout title={title} description={description}>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <!-- Breadcrumb -->
        <nav class="flex text-xs text-slate-500 mb-6" aria-label="Breadcrumb">
            <ol class="inline-flex items-center space-x-1 md:space-x-3">
                <li class="inline-flex items-center">
                    <a href="/" class="hover:text-brand-600">Home</a>
                </li>
                <li>
                    <div class="flex items-center">
                        <svg
                            class="w-3 h-3 text-slate-400 mx-1"
                            fill="currentColor"
                            viewBox="0 0 20 20"
                            ><path
                                fill-rule="evenodd"
                                d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z"
                                clip-rule="evenodd"></path></svg
                        >
                        <span class="text-slate-400" aria-current="page"
                            >Code 128 Barcode Generator</span
                        >
                    </div>
                </li>
            </ol>
        </nav>

        <!-- Header -->
        <div class="text-center md:text-left mb-10">
            <h1
                class="text-3xl md:text-4xl font-extrabold text-slate-900 tracking-tight"
            >
                Free <span class="text-gradient"
                    >Code 128 Barcode Generator</span
                >
            </h1>
            <p class="text-slate-600 mt-2 max-w-2xl">
                Encode any standard ASCII text or serial digits into a highly
                compact Code 128 format. Optimized for commercial and industrial
                labels.
            </p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
            <!-- Left Column -->
            <div
                class="lg:col-span-7 bg-white rounded-2xl border border-slate-200/80 shadow-md p-6 md:p-8 space-y-6"
            >
                <div>
                    <label
                        for="code-data"
                        class="block text-sm font-bold text-slate-700 mb-2"
                        >Code 128 Data (ASCII Characters)</label
                    >
                    <input
                        type="text"
                        id="code-data"
                        class="w-full rounded-xl border border-slate-300 px-4 py-3 text-slate-800 placeholder-slate-400 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 focus:outline-none transition-all text-sm font-mono"
                        placeholder="e.g. ITEM-100249-ABC"
                    />
                    <p
                        id="error-message"
                        class="text-xs text-red-500 mt-1 hidden font-semibold"
                    >
                    </p>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <!-- Text below -->
                    <div>
                        <label
                            for="show-text"
                            class="block text-sm font-bold text-slate-700 mb-2"
                            >Display Text Label</label
                        >
                        <select
                            id="show-text"
                            class="w-full rounded-xl border border-slate-300 px-3 py-2 text-slate-700 focus:border-brand-500 focus:outline-none bg-white text-sm"
                        >
                            <option value="true" selected
                                >Show Text below</option
                            >
                            <option value="false">Hide Text</option>
                        </select>
                    </div>

                    <!-- Height -->
                    <div>
                        <label
                            for="barcode-height"
                            class="block text-sm font-bold text-slate-700 mb-2"
                            >Height (pixels)</label
                        >
                        <input
                            type="number"
                            id="barcode-height"
                            min="40"
                            max="200"
                            value="80"
                            class="w-full rounded-xl border border-slate-300 px-3 py-2 text-slate-700 text-sm focus:border-brand-500 focus:outline-none"
                        />
                    </div>
                </div>

                <div class="flex space-x-3 pt-2">
                    <button
                        id="btn-generate"
                        class="brand-gradient hover:brand-gradient-hover text-white font-semibold px-6 py-3 rounded-xl shadow-md transition-colors flex-grow"
                    >
                        Generate Code 128 Barcode
                    </button>
                    <button
                        id="btn-reset"
                        class="border border-slate-300 hover:border-slate-400 hover:bg-slate-50 text-slate-600 px-4 py-3 rounded-xl transition-colors"
                    >
                        Reset
                    </button>
                </div>
            </div>

            <!-- Right Column: Live Preview Area -->
            <div class="lg:col-span-5 space-y-6">
                <div
                    class="bg-white rounded-2xl border border-slate-200/80 shadow-md p-6 flex flex-col items-center justify-center text-center"
                >
                    <h2 class="text-lg font-bold text-slate-900 mb-4">
                        Preview
                    </h2>

                    <div
                        class="p-6 bg-slate-50 border border-slate-150 rounded-xl relative flex items-center justify-center min-h-[220px] w-full"
                    >
                        <div
                            id="preview-placeholder"
                            class="text-slate-400 text-sm flex flex-col items-center"
                        >
                            <svg
                                class="h-12 w-12 text-slate-300 mb-2 animate-pulse"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="1.5"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="M3 5v14M7 5v14M11 5v14M14 5v14M17 5v14M21 5v14"
                                ></path>
                            </svg>
                            <span>Type data & click Generate</span>
                        </div>

                        <div
                            id="barcode-container"
                            class="hidden w-full flex items-center justify-center bg-white p-4 border rounded shadow-sm"
                        >
                            <svg
                                id="barcode-svg"
                                class="max-w-full h-auto mx-auto"></svg>
                            <canvas id="barcode-canvas" class="hidden"></canvas>
                        </div>
                    </div>

                    <div
                        id="action-buttons"
                        class="w-full grid grid-cols-2 gap-3 mt-6 hidden"
                    >
                        <button
                            id="btn-download-png"
                            class="flex items-center justify-center space-x-2 bg-slate-900 hover:bg-slate-800 text-white font-semibold py-2.5 px-4 rounded-xl shadow-sm transition-colors text-sm"
                        >
                            <svg
                                class="h-4 w-4"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                                stroke-width="2"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"
                                ></path>
                            </svg>
                            <span>Download PNG</span>
                        </button>

                        <button
                            id="btn-download-svg"
                            class="flex items-center justify-center space-x-2 border border-slate-300 hover:border-slate-400 hover:bg-slate-50 text-slate-700 font-semibold py-2.5 px-4 rounded-xl transition-colors text-sm"
                        >
                            <svg
                                class="h-4 w-4"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                                stroke-width="2"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"
                                ></path>
                            </svg>
                            <span>Download SVG</span>
                        </button>
                    </div>
                </div>

                <!-- Note card -->
                <div
                    class="bg-blue-50 border border-blue-100 rounded-2xl p-5 space-y-2"
                >
                    <h3
                        class="text-sm font-bold text-blue-900 flex items-center"
                    >
                        <svg
                            class="h-5 w-5 mr-1.5 text-blue-600"
                            viewBox="0 0 20 20"
                            fill="currentColor"
                        >
                            <path
                                fill-rule="evenodd"
                                d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z"
                                clip-rule="evenodd"></path>
                        </svg>
                        Code 128 Recommendations
                    </h3>
                    <p class="text-xs text-blue-800 leading-relaxed">
                        Code 128 is highly recommended for <strong
                            >internal labels, inventory barcodes, library
                            catalogs, asset management, and testing tags</strong
                        >. It has excellent character density and supports
                        letter/number mixes.
                    </p>
                </div>
            </div>
        </div>

        <!-- Details Section -->
        <section
            class="mt-16 bg-white rounded-2xl border border-slate-200/80 p-8 md:p-10 space-y-8"
        >
            <div>
                <h2 class="text-2xl font-bold text-slate-900 mb-4">
                    Why Choose Code 128?
                </h2>
                <p class="text-slate-600 leading-relaxed text-sm">
                    Code 128 is a very high-density linear barcode. It is
                    designed to encode a large variety of alphanumeric data with
                    maximum efficiency. Unlike simpler barcodes (like Code 39),
                    which take up massive horizontal space, Code 128 dynamically
                    shifts between three character subsets (A, B, and C) to
                    minimize label widths.
                </p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <div>
                    <h3 class="text-lg font-bold text-slate-900 mb-3">
                        Character Set Support
                    </h3>
                    <p class="text-slate-600 leading-relaxed text-sm">
                        Code 128 contains a complete set of 128 ASCII
                        characters. This includes lowercase letters (a-z),
                        uppercase letters (A-Z), numeric digits (0-9),
                        punctuation marks, and control codes like Tab or Enter.
                    </p>
                </div>
                <div>
                    <h3 class="text-lg font-bold text-slate-900 mb-3">
                        Self-Checking Security
                    </h3>
                    <p class="text-slate-600 leading-relaxed text-sm">
                        The structure has an embedded Modulo-103 checksum
                        calculated automatically from the internal values. Skan
                        devices verify this checksum before outputting the
                        decoded text, making reading errors extremely rare.
                    </p>
                </div>
            </div>
        </section>
    </div>
</BaseLayout>

<script>
    import JsBarcode from "jsbarcode";

    const dataInput = document.getElementById("code-data") as HTMLInputElement;
    const showTextSelect = document.getElementById(
        "show-text",
    ) as HTMLSelectElement;
    const heightInput = document.getElementById(
        "barcode-height",
    ) as HTMLInputElement;

    const btnGenerate = document.getElementById(
        "btn-generate",
    ) as HTMLButtonElement;
    const btnReset = document.getElementById("btn-reset") as HTMLButtonElement;

    const previewPlaceholder = document.getElementById(
        "preview-placeholder",
    ) as HTMLDivElement;
    const barcodeContainer = document.getElementById(
        "barcode-container",
    ) as HTMLDivElement;
    const actionButtons = document.getElementById(
        "action-buttons",
    ) as HTMLDivElement;
    const btnDownloadPng = document.getElementById(
        "btn-download-png",
    ) as HTMLButtonElement;
    const btnDownloadSvg = document.getElementById(
        "btn-download-svg",
    ) as HTMLButtonElement;
    const errorMessage = document.getElementById(
        "error-message",
    ) as HTMLParagraphElement;

    const svgElement = document.getElementById("barcode-svg") as any;
    const canvasElement = document.getElementById(
        "barcode-canvas",
    ) as HTMLCanvasElement;

    function generateCode128() {
        const content = dataInput.value.trim();

        // Validate ASCII only
        if (!content) {
            errorMessage.textContent = "Please enter barcode content.";
            errorMessage.classList.remove("hidden");
            return;
        }

        if (!/^[\x00-\x7F]*$/.test(content)) {
            errorMessage.textContent =
                "Invalid character: Code 128 accepts standard ASCII characters only.";
            errorMessage.classList.remove("hidden");
            return;
        }

        errorMessage.classList.add("hidden");

        const displayValue = showTextSelect.value === "true";
        const height = parseInt(heightInput.value, 10);

        try {
            JsBarcode(svgElement, content, {
                format: "CODE128",
                width: 2,
                height: height,
                displayValue: displayValue,
                margin: 15,
                background: "#ffffff",
                lineColor: "#000000",
            });

            JsBarcode(canvasElement, content, {
                format: "CODE128",
                width: 4,
                height: height * 2,
                displayValue: displayValue,
                margin: 30,
                background: "#ffffff",
                lineColor: "#000000",
            });

            previewPlaceholder.classList.add("hidden");
            barcodeContainer.classList.remove("hidden");
            actionButtons.classList.remove("hidden");
        } catch (e) {
            console.error(e);
            errorMessage.textContent = "Failed to generate Code 128 barcode.";
            errorMessage.classList.remove("hidden");
        }
    }

    btnGenerate.addEventListener("click", generateCode128);

    btnReset.addEventListener("click", () => {
        dataInput.value = "";
        showTextSelect.value = "true";
        heightInput.value = "80";
        errorMessage.classList.add("hidden");

        previewPlaceholder.classList.remove("hidden");
        barcodeContainer.classList.add("hidden");
        actionButtons.classList.add("hidden");
    });

    btnDownloadPng.addEventListener("click", () => {
        const dataUrl = canvasElement.toDataURL("image/png");
        const link = document.createElement("a");
        link.href = dataUrl;
        link.download = `code128-${Date.now()}.png`;
        document.body.appendChild(link);
        link.click();
        document.body.removeChild(link);
    });

    btnDownloadSvg.addEventListener("click", () => {
        const serializer = new XMLSerializer();
        const svgStr = serializer.serializeToString(svgElement);
        const blob = new Blob([svgStr], {
            type: "image/svg+xml;charset=utf-8",
        });
        const url = URL.createObjectURL(blob);
        const link = document.createElement("a");
        link.href = url;
        link.download = `code128-${Date.now()}.svg`;
        document.body.appendChild(link);
        link.click();
        document.body.removeChild(link);
        URL.revokeObjectURL(url);
    });

    dataInput.addEventListener("keydown", (e) => {
        if (e.key === "Enter") {
            generateCode128();
        }
    });
</script>
