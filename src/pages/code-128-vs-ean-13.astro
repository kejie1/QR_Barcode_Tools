---
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "Code 128 vs EAN-13 - Which Barcode Format to Use";
const description =
    "Compare Code 128 and EAN-13 barcode formats for product labels, SKU tags, inventory IDs, and retail-style barcodes.";
---

<BaseLayout title={title} description={description}>
    <main class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <nav class="mb-8 text-sm text-slate-500">
            <a href="/" class="hover:text-brand-600">Home</a>
            <span class="mx-2">/</span>
            <span>Code 128 vs EAN-13</span>
        </nav>

        <section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm sm:p-8">
            <p class="text-sm font-bold uppercase tracking-wide text-brand-600">Barcode format guide</p>
            <h1 class="mt-3 text-3xl font-extrabold tracking-tight text-slate-900 sm:text-4xl">
                Code 128 vs EAN-13
            </h1>
            <p class="mt-4 max-w-3xl text-base leading-7 text-slate-600">
                Code 128 and EAN-13 solve different barcode jobs. Use this comparison to choose the right generator before you create a barcode image.
            </p>
        </section>

        <section class="mt-10 grid gap-6 md:grid-cols-2">
            <article class="rounded-2xl border border-slate-200 bg-white p-6">
                <h2 class="text-2xl font-bold text-slate-900">Use Code 128 when...</h2>
                <ul class="mt-4 space-y-3 text-sm leading-6 text-slate-600">
                    <li>You need letters, numbers, or mixed symbols.</li>
                    <li>The code is for internal inventory, assets, shelves, or batches.</li>
                    <li>The value is not a retail product number.</li>
                </ul>
                <a href="/code-128-barcode-generator/" class="mt-6 inline-flex text-sm font-bold text-brand-600 hover:text-brand-700">Open Code 128 generator &rarr;</a>
            </article>
            <article class="rounded-2xl border border-slate-200 bg-white p-6">
                <h2 class="text-2xl font-bold text-slate-900">Use EAN-13 when...</h2>
                <ul class="mt-4 space-y-3 text-sm leading-6 text-slate-600">
                    <li>You have a 13-digit retail-style product identifier.</li>
                    <li>You need a product label mockup or packaging preview.</li>
                    <li>You want a barcode with a numeric check digit.</li>
                </ul>
                <a href="/ean-13-barcode-generator/" class="mt-6 inline-flex text-sm font-bold text-brand-600 hover:text-brand-700">Open EAN-13 generator &rarr;</a>
            </article>
        </section>
    </main>
</BaseLayout>
