---
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "WiFi QR Code Generator - Share Your WiFi Securely";
const description =
    "Create a free WiFi QR code to share your network password. No typing required to join. Fully secure and processed locally in your browser.";
---

<BaseLayout title={title} description={description}>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <!-- Breadcrumb -->
        <nav class="flex text-xs text-slate-500 mb-6" aria-label="Breadcrumb">
            <ol class="inline-flex items-center space-x-1 md:space-x-3">
                <li class="inline-flex items-center">
                    <a href="/" class="hover:text-brand-600">Home</a>
                </li>
                <li>
                    <div class="flex items-center">
                        <svg
                            class="w-3 h-3 text-slate-400 mx-1"
                            fill="currentColor"
                            viewBox="0 0 20 20"
                            ><path
                                fill-rule="evenodd"
                                d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z"
                                clip-rule="evenodd"></path></svg
                        >
                        <span class="text-slate-400" aria-current="page"
                            >WiFi QR Code Generator</span
                        >
                    </div>
                </li>
            </ol>
        </nav>

        <!-- Header -->
        <div class="text-center md:text-left mb-10">
            <h1
                class="text-3xl md:text-4xl font-extrabold text-slate-900 tracking-tight"
            >
                Free <span class="text-gradient">WiFi QR Code Generator</span>
            </h1>
            <p class="text-slate-600 mt-2 max-w-2xl">
                Share your home or office wireless network without giving away
                your password in plain text. Just generate, print or save, and
                scan to connect automatically.
            </p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
            <!-- Left Column: Settings Form -->
            <div
                class="lg:col-span-7 bg-white rounded-2xl border border-slate-200/80 shadow-md p-6 md:p-8 space-y-6"
            >
                <div>
                    <label
                        for="wifi-ssid"
                        class="block text-sm font-bold text-slate-700 mb-2"
                        >Network Name (SSID)</label
                    >
                    <input
                        type="text"
                        id="wifi-ssid"
                        class="w-full rounded-xl border border-slate-300 px-4 py-3 text-slate-800 placeholder-slate-400 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 focus:outline-none transition-all text-sm"
                        placeholder="e.g. My_Home_WiFi"
                    />
                </div>

                <div>
                    <label
                        for="wifi-password"
                        class="block text-sm font-bold text-slate-700 mb-2"
                        >Password</label
                    >
                    <input
                        type="password"
                        id="wifi-password"
                        class="w-full rounded-xl border border-slate-300 px-4 py-3 text-slate-800 placeholder-slate-400 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 focus:outline-none transition-all text-sm"
                        placeholder="Enter WiFi password..."
                    />
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <!-- Encryption -->
                    <div>
                        <label
                            for="wifi-encryption"
                            class="block text-sm font-bold text-slate-700 mb-2"
                            >Network Security</label
                        >
                        <select
                            id="wifi-encryption"
                            class="w-full rounded-xl border border-slate-300 px-3 py-2 text-slate-700 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 focus:outline-none bg-white text-sm"
                        >
                            <option value="WPA" selected
                                >WPA/WPA2/WPA3 (Standard)</option
                            >
                            <option value="WEP">WEP (Legacy)</option>
                            <option value="nopass">None (Open Network)</option>
                        </select>
                    </div>

                    <!-- Hidden network -->
                    <div class="flex items-center h-full pt-6 md:pt-8 pl-1">
                        <input
                            type="checkbox"
                            id="wifi-hidden"
                            class="h-4.5 w-4.5 rounded border-slate-300 text-brand-600 focus:ring-brand-200"
                        />
                        <label
                            for="wifi-hidden"
                            class="ml-2 block text-sm font-semibold text-slate-700 select-none"
                        >
                            Hidden Network SSID
                        </label>
                    </div>
                </div>

                <!-- Customizable Colors for Premium Look -->
                <div
                    class="grid grid-cols-1 md:grid-cols-2 gap-6 pt-2 border-t border-slate-100"
                >
                    <div>
                        <label
                            for="qr-fg"
                            class="block text-sm font-bold text-slate-700 mb-2"
                            >QR Color (Dark)</label
                        >
                        <input
                            type="color"
                            id="qr-fg"
                            value="#000000"
                            class="h-10 w-full p-1 border border-slate-300 rounded-xl cursor-pointer bg-white"
                        />
                    </div>
                    <div>
                        <label
                            for="qr-bg"
                            class="block text-sm font-bold text-slate-700 mb-2"
                            >Background Color (Light)</label
                        >
                        <input
                            type="color"
                            id="qr-bg"
                            value="#ffffff"
                            class="h-10 w-full p-1 border border-slate-300 rounded-xl cursor-pointer bg-white"
                        />
                    </div>
                </div>

                <div class="flex space-x-3 pt-2">
                    <button
                        id="btn-generate"
                        class="brand-gradient hover:brand-gradient-hover text-white font-semibold px-6 py-3 rounded-xl shadow-md transition-colors flex-grow"
                    >
                        Generate WiFi QR Code
                    </button>
                    <button
                        id="btn-reset"
                        class="border border-slate-300 hover:border-slate-400 hover:bg-slate-50 text-slate-600 px-4 py-3 rounded-xl transition-colors"
                    >
                        Reset
                    </button>
                </div>
            </div>

            <!-- Right Column: Live Preview Area -->
            <div class="lg:col-span-5 space-y-6">
                <div
                    class="bg-white rounded-2xl border border-slate-200/80 shadow-md p-6 flex flex-col items-center justify-center text-center"
                >
                    <h2 class="text-lg font-bold text-slate-900 mb-4">
                        Preview
                    </h2>

                    <div
                        class="p-6 bg-slate-50 border border-slate-150 rounded-xl relative flex items-center justify-center min-h-[260px] min-w-[260px]"
                    >
                        <div
                            id="preview-placeholder"
                            class="text-slate-400 text-sm flex flex-col items-center"
                        >
                            <svg
                                class="h-12 w-12 text-slate-300 mb-2 animate-pulse"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="1.5"
                            >
                                <rect x="3" y="3" width="18" height="18" rx="2"
                                ></rect>
                                <path
                                    d="M8.111 16.404a5.5 5.5 0 017.778 0M12 20h.01M5.283 13.576a9 9 0 0113.434 0"
                                ></path>
                            </svg>
                            <span>Fill details & generate WiFi QR</span>
                        </div>

                        <div id="qr-container" class="hidden">
                            <img
                                id="qr-image"
                                src=""
                                alt="WiFi QR Code"
                                class="max-w-full h-auto mx-auto border shadow-sm rounded bg-white"
                            />
                        </div>
                    </div>

                    <div
                        id="action-buttons"
                        class="w-full grid grid-cols-2 gap-3 mt-6 hidden"
                    >
                        <button
                            id="btn-download-png"
                            class="flex items-center justify-center space-x-2 bg-slate-900 hover:bg-slate-800 text-white font-semibold py-2.5 px-4 rounded-xl shadow-sm transition-colors text-sm"
                        >
                            <svg
                                class="h-4 w-4"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                                stroke-width="2"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"
                                ></path>
                            </svg>
                            <span>Download PNG</span>
                        </button>

                        <button
                            id="btn-download-svg"
                            class="flex items-center justify-center space-x-2 border border-slate-300 hover:border-slate-400 hover:bg-slate-50 text-slate-700 font-semibold py-2.5 px-4 rounded-xl transition-colors text-sm"
                        >
                            <svg
                                class="h-4 w-4"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                                stroke-width="2"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"
                                ></path>
                            </svg>
                            <span>Download SVG</span>
                        </button>
                    </div>
                </div>

                <!-- Privacy & Security Note -->
                <div
                    class="bg-blue-50 border border-blue-100 rounded-2xl p-5 space-y-3"
                >
                    <h3
                        class="text-sm font-bold text-blue-900 flex items-center"
                    >
                        <svg
                            class="h-5 w-5 mr-1.5 text-blue-600"
                            viewBox="0 0 20 20"
                            fill="currentColor"
                        >
                            <path
                                fill-rule="evenodd"
                                d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"
                            ></path>
                        </svg>
                        WiFi Code Security Notice
                    </h3>
                    <p class="text-xs text-blue-800 leading-relaxed">
                        <strong
                            >Your WiFi details are processed locally in your
                            browser and are not uploaded.</strong
                        > Since we run entirely client-side, your private router credentials
                        never leave your system.
                    </p>
                </div>
            </div>
        </div>

        <!-- Details Section -->
        <section
            class="mt-16 bg-white rounded-2xl border border-slate-200/80 p-8 md:p-10 space-y-8"
        >
            <div>
                <h2 class="text-2xl font-bold text-slate-900 mb-4">
                    How Do WiFi QR Codes Work?
                </h2>
                <p class="text-slate-600 leading-relaxed text-sm">
                    A WiFi QR code encodes network parameters according to a
                    standard format readable by iOS, iPadOS, and Android camera
                    systems. When a user points their device camera at the code,
                    the operating system decodes the network name, type, and
                    password and presents a single-tap "Join Network" prompt.
                </p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <div>
                    <h3 class="text-lg font-bold text-slate-900 mb-3">
                        Which encryption standard do I have?
                    </h3>
                    <p class="text-slate-600 leading-relaxed text-sm">
                        For almost all home and business routers configured
                        today, <strong>WPA/WPA2/WPA3</strong> is the standard. WEP
                        is obsolete and rarely used unless on legacy devices from
                        early 2000s. If your network does not require a password,
                        choose <strong>None (Open Network)</strong>.
                    </p>
                </div>
                <div>
                    <h3 class="text-lg font-bold text-slate-900 mb-3">
                        Connecting to Hidden Networks
                    </h3>
                    <p class="text-slate-600 leading-relaxed text-sm">
                        If your router is configured to not broadcast its SSID
                        (Hidden Network SSID), check the "Hidden Network SSID"
                        checkbox. This appends a hidden flag in the generated
                        code so that scanning smartphones know to seek out and
                        join the invisible network.
                    </p>
                </div>
            </div>
        </section>
    </div>
</BaseLayout>

<script>
    import QRCode from "qrcode";

    const ssidInput = document.getElementById("wifi-ssid") as HTMLInputElement;
    const passwordInput = document.getElementById(
        "wifi-password",
    ) as HTMLInputElement;
    const encryptionSelect = document.getElementById(
        "wifi-encryption",
    ) as HTMLSelectElement;
    const hiddenCheckbox = document.getElementById(
        "wifi-hidden",
    ) as HTMLInputElement;

    const fgColorInput = document.getElementById("qr-fg") as HTMLInputElement;
    const bgColorInput = document.getElementById("qr-bg") as HTMLInputElement;

    const btnGenerate = document.getElementById(
        "btn-generate",
    ) as HTMLButtonElement;
    const btnReset = document.getElementById("btn-reset") as HTMLButtonElement;

    const previewPlaceholder = document.getElementById(
        "preview-placeholder",
    ) as HTMLDivElement;
    const qrContainer = document.getElementById(
        "qr-container",
    ) as HTMLDivElement;
    const qrImage = document.getElementById("qr-image") as HTMLImageElement;
    const actionButtons = document.getElementById(
        "action-buttons",
    ) as HTMLDivElement;
    const btnDownloadPng = document.getElementById(
        "btn-download-png",
    ) as HTMLButtonElement;
    const btnDownloadSvg = document.getElementById(
        "btn-download-svg",
    ) as HTMLButtonElement;

    let currentPngDataUrl = "";
    let currentSvgContent = "";

    function generateWiFiCode() {
        const ssid = ssidInput.value.trim();
        if (!ssid) {
            alert("Please enter a network name (SSID).");
            return;
        }

        const password = passwordInput.value;
        const encryption = encryptionSelect.value;
        const isHidden = hiddenCheckbox.checked;

        // WiFi Format: WIFI:S:<SSID>;T:<WPA|WEP|nopass>;P:<PASSWORD>;H:<true|false>;;
        // Escaping special characters: backslash \ and semicolon ; and colon : should be escaped with a backslash if they appear in SSID or Password
        const escapeString = (str: string) => {
            return str
                .replace(/\\/g, "\\\\")
                .replace(/;/g, "\\;")
                .replace(/:/g, "\\:")
                .replace(/,/g, "\\,");
        };

        const escapedSSID = escapeString(ssid);
        const escapedPassword = escapeString(password);

        let qrPayload = `WIFI:S:${escapedSSID};T:${encryption};`;
        if (encryption !== "nopass") {
            qrPayload += `P:${escapedPassword};`;
        }
        if (isHidden) {
            qrPayload += `H:true;`;
        }
        qrPayload += ";";

        const fgColor = fgColorInput.value;
        const bgColor = bgColorInput.value;

        try {
            QRCode.toDataURL(
                qrPayload,
                {
                    width: 380,
                    margin: 2,
                    errorCorrectionLevel: "M",
                    color: {
                        dark: fgColor,
                        light: bgColor,
                    },
                },
                (err, url) => {
                    if (err) throw err;
                    currentPngDataUrl = url;
                    qrImage.src = url;
                },
            );

            QRCode.toString(
                qrPayload,
                {
                    type: "svg",
                    width: 380,
                    margin: 2,
                    errorCorrectionLevel: "M",
                    color: {
                        dark: fgColor,
                        light: bgColor,
                    },
                },
                (err, svgString) => {
                    if (err) throw err;
                    currentSvgContent = svgString;
                },
            );

            previewPlaceholder.classList.add("hidden");
            qrContainer.classList.remove("hidden");
            actionButtons.classList.remove("hidden");
        } catch (e) {
            console.error(e);
            alert("Failed to generate QR Code.");
        }
    }

    btnGenerate.addEventListener("click", generateWiFiCode);

    btnReset.addEventListener("click", () => {
        ssidInput.value = "";
        passwordInput.value = "";
        encryptionSelect.value = "WPA";
        hiddenCheckbox.checked = false;
        fgColorInput.value = "#000000";
        bgColorInput.value = "#ffffff";

        previewPlaceholder.classList.remove("hidden");
        qrContainer.classList.add("hidden");
        actionButtons.classList.add("hidden");
        qrImage.src = "";
        currentPngDataUrl = "";
        currentSvgContent = "";
    });

    btnDownloadPng.addEventListener("click", () => {
        if (!currentPngDataUrl) return;
        const link = document.createElement("a");
        link.href = currentPngDataUrl;
        link.download = `wifi-qr-${Date.now()}.png`;
        document.body.appendChild(link);
        link.click();
        document.body.removeChild(link);
    });

    btnDownloadSvg.addEventListener("click", () => {
        if (!currentSvgContent) return;
        const blob = new Blob([currentSvgContent], {
            type: "image/svg+xml;charset=utf-8",
        });
        const blobUrl = URL.createObjectURL(blob);
        const link = document.createElement("a");
        link.href = blobUrl;
        link.download = `wifi-qr-${Date.now()}.svg`;
        document.body.appendChild(link);
        link.click();
        document.body.removeChild(link);
        URL.revokeObjectURL(blobUrl);
    });

    // Open Network configuration toggle
    encryptionSelect.addEventListener("change", () => {
        if (encryptionSelect.value === "nopass") {
            passwordInput.disabled = true;
            passwordInput.placeholder =
                "No password required for open networks";
            passwordInput.value = "";
        } else {
            passwordInput.disabled = false;
            passwordInput.placeholder = "Enter WiFi password...";
        }
    });
</script>
