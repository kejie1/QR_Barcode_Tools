---
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "EAN-13 Barcode Generator - Create 13 Digit Barcodes";
const description =
    "Create an EAN-13 barcode online for free. Enter 12 digits to calculate the 13th checksum digit or validate an existing 13 digit barcode.";
---

<BaseLayout title={title} description={description}>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <!-- Breadcrumb -->
        <nav class="flex text-xs text-slate-500 mb-6" aria-label="Breadcrumb">
            <ol class="inline-flex items-center space-x-1 md:space-x-3">
                <li class="inline-flex items-center">
                    <a href="/" class="hover:text-brand-600">Home</a>
                </li>
                <li>
                    <div class="flex items-center">
                        <svg
                            class="w-3 h-3 text-slate-400 mx-1"
                            fill="currentColor"
                            viewBox="0 0 20 20"
                            ><path
                                fill-rule="evenodd"
                                d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z"
                                clip-rule="evenodd"></path></svg
                        >
                        <span class="text-slate-400" aria-current="page"
                            >EAN-13 Barcode Generator</span
                        >
                    </div>
                </li>
            </ol>
        </nav>

        <!-- Header -->
        <div class="text-center md:text-left mb-10">
            <h1
                class="text-3xl md:text-4xl font-extrabold text-slate-900 tracking-tight"
            >
                Free <span class="text-gradient">EAN-13 Barcode Generator</span
                > for 13 Digit Barcodes
            </h1>
            <p class="text-slate-600 mt-2 max-w-2xl">
                Create an EAN-13 barcode for a 13 digit retail code. Enter 12
                digits to add the checksum automatically, or paste an existing
                13 digit barcode number to validate and download it.
            </p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
            <!-- Left Column -->
            <div
                class="lg:col-span-7 bg-white rounded-2xl border border-slate-200/80 shadow-md p-6 md:p-8 space-y-6"
            >
                <div>
                    <label
                        for="ean-data"
                        class="block text-sm font-bold text-slate-700 mb-2"
                        >EAN-13 Code (12 or 13 digits)</label
                    >
                    <input
                        type="text"
                        id="ean-data"
                        maxlength="13"
                        class="w-full rounded-xl border border-slate-300 px-4 py-3 text-slate-800 placeholder-slate-400 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 focus:outline-none transition-all text-sm font-mono tracking-widest"
                        placeholder="e.g. 400638133393"
                    />
                    <p
                        id="error-message"
                        class="text-xs mt-1.5 hidden font-semibold"
                    >
                    </p>
                </div>

                <div
                    class="p-4 bg-slate-50 border border-slate-200/60 rounded-xl space-y-2"
                >
                    <h3
                        class="text-xs font-bold text-slate-700 uppercase tracking-wider"
                    >
                        Checksum Calculator Helper
                    </h3>
                    <p class="text-xs text-slate-500 leading-relaxed">
                        - Enter <strong>12 digits</strong>, and we will
                        instantly calculate the correct 13th checksum digit.
                        <br />- Enter <strong>13 digits</strong>, and we will
                        verify if the checksum is correct and auto-fix it if
                        necessary.
                    </p>
                </div>

                <div class="flex space-x-3 pt-2">
                    <button
                        id="btn-generate"
                        class="brand-gradient hover:brand-gradient-hover text-white font-semibold px-6 py-3 rounded-xl shadow-md transition-colors flex-grow"
                    >
                        Create EAN-13 Barcode
                    </button>
                    <button
                        id="btn-reset"
                        class="border border-slate-300 hover:border-slate-400 hover:bg-slate-50 text-slate-600 px-4 py-3 rounded-xl transition-colors"
                    >
                        Reset
                    </button>
                </div>
            </div>

            <!-- Right Column: Live Preview Area -->
            <div class="lg:col-span-5 space-y-6">
                <div
                    class="bg-white rounded-2xl border border-slate-200/80 shadow-md p-6 flex flex-col items-center justify-center text-center"
                >
                    <h2 class="text-lg font-bold text-slate-900 mb-4">
                        Preview
                    </h2>

                    <div
                        class="p-6 bg-slate-50 border border-slate-150 rounded-xl relative flex items-center justify-center min-h-[220px] w-full"
                    >
                        <div
                            id="preview-placeholder"
                            class="text-slate-400 text-sm flex flex-col items-center"
                        >
                            <svg
                                class="h-12 w-12 text-slate-300 mb-2 animate-pulse"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="1.5"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="M3 5v14M7 5v14M11 5v14M14 5v14M17 5v14M21 5v14"
                                ></path>
                            </svg>
                            <span>Type 12 or 13 digits to generate</span>
                        </div>

                        <div
                            id="barcode-container"
                            class="hidden w-full flex items-center justify-center bg-white p-4 border rounded shadow-sm"
                        >
                            <svg
                                id="barcode-svg"
                                class="max-w-full h-auto mx-auto"></svg>
                            <canvas id="barcode-canvas" class="hidden"></canvas>
                        </div>
                    </div>

                    <div
                        id="action-buttons"
                        class="w-full grid grid-cols-2 gap-3 mt-6 hidden"
                    >
                        <button
                            id="btn-download-png"
                            class="flex items-center justify-center space-x-2 bg-slate-900 hover:bg-slate-800 text-white font-semibold py-2.5 px-4 rounded-xl shadow-sm transition-colors text-sm"
                        >
                            <svg
                                class="h-4 w-4"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                                stroke-width="2"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"
                                ></path>
                            </svg>
                            <span>Download PNG</span>
                        </button>

                        <button
                            id="btn-download-svg"
                            class="flex items-center justify-center space-x-2 border border-slate-300 hover:border-slate-400 hover:bg-slate-50 text-slate-700 font-semibold py-2.5 px-4 rounded-xl transition-colors text-sm"
                        >
                            <svg
                                class="h-4 w-4"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                                stroke-width="2"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"
                                ></path>
                            </svg>
                            <span>Download SVG</span>
                        </button>
                    </div>
                </div>

                <!-- Disclaimer -->
                <div
                    class="bg-amber-50 border border-amber-100 rounded-2xl p-5 space-y-3"
                >
                    <h3
                        class="text-sm font-bold text-amber-950 flex items-center"
                    >
                        <svg
                            class="h-5 w-5 mr-1.5 text-amber-700"
                            viewBox="0 0 20 20"
                            fill="currentColor"
                        >
                            <path
                                fill-rule="evenodd"
                                d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z"
                                clip-rule="evenodd"></path>
                        </svg>
                        GS1 Official Disclaimer
                    </h3>
                    <p class="text-xs text-amber-900 leading-relaxed text-left">
                        <strong
                            >EAN-13 numbers used for retail products should be
                            issued by an authorized organization such as GS1.</strong
                        > Generating custom barcode graphics here does not grant legal
                        copyright or registration to those product numbers.
                    </p>
                </div>
            </div>
        </div>

        <!-- Details Section -->
        <section
            class="mt-16 bg-white rounded-2xl border border-slate-200/80 p-8 md:p-10 space-y-8"
        >
            <div>
                <h2 class="text-2xl font-bold text-slate-900 mb-4">
                    How is the EAN-13 Checksum Calculated?
                </h2>
                <p class="text-slate-600 leading-relaxed text-sm">
                    The final 13th digit of an EAN-13 barcode is a modulo-10
                    checksum calculated from the preceding 12 digits. The
                    formula operates as follows:
                </p>
                <div
                    class="bg-slate-50 border rounded-xl p-5 text-sm font-mono mt-4 text-slate-700 space-y-1.5"
                >
                    <p>
                        1. Sum all the digits at odd positions (1st, 3rd, 5th,
                        etc.) -> OddSum
                    </p>
                    <p>
                        2. Sum all the digits at even positions (2nd, 4th, 6th,
                        etc.) and multiply by 3 -> EvenSum * 3
                    </p>
                    <p>
                        3. Add both values -> TotalSum = OddSum + (EvenSum * 3)
                    </p>
                    <p>4. Checksum = (10 - (TotalSum Modulo 10)) Modulo 10</p>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <div>
                    <h3 class="text-lg font-bold text-slate-900 mb-3">
                        Usage in Global Logistics
                    </h3>
                    <p class="text-slate-600 leading-relaxed text-sm">
                        EAN-13 barcodes are 13 digit barcode formats used
                        globally on physical packages in supermarkets, physical
                        stores, and e-commerce nodes. They allow check-out laser
                        scanners to identify inventory databases
                        instantaneously.
                    </p>
                </div>
                <div>
                    <h3 class="text-lg font-bold text-slate-900 mb-3">
                        Country Prefixes
                    </h3>
                    <p class="text-slate-600 leading-relaxed text-sm">
                        The first 3 digits of an EAN-13 barcode represent the
                        GS1 country prefix (identifying the national GS1
                        organization that issued the code, which is not
                        necessarily where the product was manufactured).
                    </p>
                </div>
            </div>

            <div class="pt-6 border-t border-slate-100">
                <h2 class="text-xl font-bold text-slate-900 mb-4">
                    How to get a 13 digit barcode
                </h2>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                    <div class="rounded-xl bg-slate-50 border border-slate-200 p-5">
                        <h3 class="text-sm font-bold text-slate-900 mb-2">
                            1. Use a valid product number
                        </h3>
                        <p class="text-sm text-slate-600 leading-relaxed">
                            For retail products, obtain a legitimate GTIN or
                            EAN number from GS1 or the appropriate issuer for
                            your market before printing packaging.
                        </p>
                    </div>
                    <div class="rounded-xl bg-slate-50 border border-slate-200 p-5">
                        <h3 class="text-sm font-bold text-slate-900 mb-2">
                            2. Generate the EAN13 barcode
                        </h3>
                        <p class="text-sm text-slate-600 leading-relaxed">
                            Enter the first 12 digits to calculate the checksum
                            automatically, or paste all 13 digits to validate
                            an existing EAN13 barcode.
                        </p>
                    </div>
                    <div class="rounded-xl bg-slate-50 border border-slate-200 p-5">
                        <h3 class="text-sm font-bold text-slate-900 mb-2">
                            3. Test before publishing
                        </h3>
                        <p class="text-sm text-slate-600 leading-relaxed">
                            Download the barcode image, print a sample, and
                            scan it with multiple devices before using it on
                            labels, inventory sheets, or product packaging.
                        </p>
                    </div>
                </div>
            </div>
        </section>
    </div>
</BaseLayout>

<script>
    import JsBarcode from "jsbarcode";

    const dataInput = document.getElementById("ean-data") as HTMLInputElement;
    const btnGenerate = document.getElementById(
        "btn-generate",
    ) as HTMLButtonElement;
    const btnReset = document.getElementById("btn-reset") as HTMLButtonElement;

    const previewPlaceholder = document.getElementById(
        "preview-placeholder",
    ) as HTMLDivElement;
    const barcodeContainer = document.getElementById(
        "barcode-container",
    ) as HTMLDivElement;
    const actionButtons = document.getElementById(
        "action-buttons",
    ) as HTMLDivElement;
    const btnDownloadPng = document.getElementById(
        "btn-download-png",
    ) as HTMLButtonElement;
    const btnDownloadSvg = document.getElementById(
        "btn-download-svg",
    ) as HTMLButtonElement;
    const errorMessage = document.getElementById(
        "error-message",
    ) as HTMLParagraphElement;

    const svgElement = document.getElementById("barcode-svg") as any;
    const canvasElement = document.getElementById(
        "barcode-canvas",
    ) as HTMLCanvasElement;

    function calculateEan13Checksum(code12: string): number {
        let sum = 0;
        for (let i = 0; i < 12; i++) {
            let digit = parseInt(code12.charAt(i), 10);
            if (i % 2 === 1) {
                // Even positions (1-based, indices 1,3,5,7,9,11)
                sum += digit * 3;
            } else {
                // Odd positions (1-based, indices 0,2,4,6,8,10)
                sum += digit;
            }
        }
        let remainder = sum % 10;
        return remainder === 0 ? 0 : 10 - remainder;
    }

    function generateEan13() {
        const rawContent = dataInput.value.replace(/\s+/g, "");

        if (!rawContent) {
            errorMessage.textContent = "Please enter numeric digits to encode.";
            errorMessage.className =
                "text-xs text-red-500 mt-1.5 font-semibold";
            errorMessage.classList.remove("hidden");
            return;
        }

        if (!/^\d+$/.test(rawContent)) {
            errorMessage.textContent =
                "Invalid characters. EAN-13 barcodes accept only numeric digits (0-9).";
            errorMessage.className =
                "text-xs text-red-500 mt-1.5 font-semibold";
            errorMessage.classList.remove("hidden");
            return;
        }

        let finalValue = "";
        let hintText = "";

        if (rawContent.length === 12) {
            const checksum = calculateEan13Checksum(rawContent);
            finalValue = rawContent + checksum;
            hintText = `Success! Added calculated 13th checksum digit: ${checksum}.`;
        } else if (rawContent.length === 13) {
            const expectedChecksum = calculateEan13Checksum(
                rawContent.slice(0, 12),
            );
            const actualChecksum = parseInt(rawContent.charAt(12), 10);
            if (expectedChecksum !== actualChecksum) {
                finalValue = rawContent.slice(0, 12) + expectedChecksum;
                hintText = `Notice: Incorrect checksum ${actualChecksum}. Auto-corrected to ${expectedChecksum}.`;
            } else {
                finalValue = rawContent;
                hintText = "Success! Compliant 13-digit EAN-13 code detected.";
            }
        } else {
            errorMessage.textContent = `Error: EAN-13 must be exactly 12 or 13 digits. Current count: ${rawContent.length}.`;
            errorMessage.className =
                "text-xs text-red-500 mt-1.5 font-semibold";
            errorMessage.classList.remove("hidden");
            return;
        }

        // Output positive feedback
        errorMessage.textContent = hintText;
        errorMessage.className =
            "text-xs text-blue-600 mt-1.5 font-semibold bg-blue-50 px-2.5 py-1 rounded-lg border border-blue-100";
        errorMessage.classList.remove("hidden");

        try {
            JsBarcode(svgElement, finalValue, {
                format: "EAN13",
                width: 2,
                height: 100,
                displayValue: true,
                margin: 15,
                background: "#ffffff",
                lineColor: "#000000",
            });

            JsBarcode(canvasElement, finalValue, {
                format: "EAN13",
                width: 4,
                height: 200,
                displayValue: true,
                margin: 30,
                background: "#ffffff",
                lineColor: "#000000",
            });

            previewPlaceholder.classList.add("hidden");
            barcodeContainer.classList.remove("hidden");
            actionButtons.classList.remove("hidden");
        } catch (e) {
            console.error(e);
            errorMessage.textContent =
                "Render Error: Failed to generate EAN-13 graphics.";
            errorMessage.className =
                "text-xs text-red-500 mt-1.5 font-semibold";
            errorMessage.classList.remove("hidden");
        }
    }

    btnGenerate.addEventListener("click", generateEan13);

    btnReset.addEventListener("click", () => {
        dataInput.value = "";
        errorMessage.classList.add("hidden");

        previewPlaceholder.classList.remove("hidden");
        barcodeContainer.classList.add("hidden");
        actionButtons.classList.add("hidden");
    });

    btnDownloadPng.addEventListener("click", () => {
        const dataUrl = canvasElement.toDataURL("image/png");
        const link = document.createElement("a");
        link.href = dataUrl;
        link.download = `ean13-${Date.now()}.png`;
        document.body.appendChild(link);
        link.click();
        document.body.removeChild(link);
    });

    btnDownloadSvg.addEventListener("click", () => {
        const serializer = new XMLSerializer();
        const svgStr = serializer.serializeToString(svgElement);
        const blob = new Blob([svgStr], {
            type: "image/svg+xml;charset=utf-8",
        });
        const url = URL.createObjectURL(blob);
        const link = document.createElement("a");
        link.href = url;
        link.download = `ean13-${Date.now()}.svg`;
        document.body.appendChild(link);
        link.click();
        document.body.removeChild(link);
        URL.revokeObjectURL(url);
    });

    dataInput.addEventListener("keydown", (e) => {
        if (e.key === "Enter") {
            generateEan13();
        }
    });
</script>
