---
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "QR Code for Website - Create a Website Link QR Code";
const description =
    "Create a QR code for a website URL and learn what to check before printing or sharing it. Free browser-based website QR code workflow.";
---

<BaseLayout title={title} description={description}>
    <main class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <nav class="mb-8 text-sm text-slate-500">
            <a href="/" class="hover:text-brand-600">Home</a>
            <span class="mx-2">/</span>
            <span>QR Code for Website</span>
        </nav>

        <section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm sm:p-8">
            <p class="text-sm font-bold uppercase tracking-wide text-brand-600">Website QR workflow</p>
            <h1 class="mt-3 text-3xl font-extrabold tracking-tight text-slate-900 sm:text-4xl">
                Create a QR Code for a Website
            </h1>
            <p class="mt-4 max-w-3xl text-base leading-7 text-slate-600">
                A website QR code is useful for menus, packaging, posters, storefronts, event pages, and printed handouts. Generate it in your browser, test the scan, then download a clean PNG or SVG.
            </p>
            <div class="mt-6 flex flex-wrap gap-3">
                <a href="/qr-code-generator/" class="rounded-xl bg-brand-600 px-5 py-3 text-sm font-bold text-white hover:bg-brand-700">Open QR Code Generator</a>
                <a href="/url-qr-code-generator/" class="rounded-xl border border-slate-200 px-5 py-3 text-sm font-bold text-slate-700 hover:bg-slate-50">URL QR Code Tool</a>
            </div>
        </section>

        <section class="mt-10 grid gap-6 md:grid-cols-3">
            <article class="rounded-2xl border border-slate-200 bg-white p-6">
                <h2 class="text-lg font-bold text-slate-900">Use the final URL</h2>
                <p class="mt-2 text-sm leading-6 text-slate-600">Paste the canonical page URL after redirects are configured so printed codes do not point to temporary links.</p>
            </article>
            <article class="rounded-2xl border border-slate-200 bg-white p-6">
                <h2 class="text-lg font-bold text-slate-900">Keep contrast high</h2>
                <p class="mt-2 text-sm leading-6 text-slate-600">Use strong foreground and background contrast, especially for flyers, labels, and small print sizes.</p>
            </article>
            <article class="rounded-2xl border border-slate-200 bg-white p-6">
                <h2 class="text-lg font-bold text-slate-900">Test before publishing</h2>
                <p class="mt-2 text-sm leading-6 text-slate-600">Scan the code from a phone and check that the destination page loads on mobile before printing in bulk.</p>
            </article>
        </section>
    </main>
</BaseLayout>
