---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
    const posts = await getCollection("blog");
    return posts.map((post) => ({
        params: { slug: post.slug },
        props: { post },
    }));
}

const { post } = Astro.props;
const { Content } = await post.render();

// SEO Parameters
const title = `${post.data.title} | QR Barcode Tools`;
const description = post.data.description;
---

<BaseLayout title={title} description={description}>
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <!-- Breadcrumb -->
        <nav class="flex text-xs text-slate-500 mb-6" aria-label="Breadcrumb">
            <ol class="inline-flex items-center space-x-1 md:space-x-3">
                <li class="inline-flex items-center">
                    <a href="/" class="hover:text-brand-600">Home</a>
                </li>
                <li>
                    <div class="flex items-center">
                        <svg
                            class="w-3 h-3 text-slate-400 mx-1"
                            fill="currentColor"
                            viewBox="0 0 20 20"
                            ><path
                                fill-rule="evenodd"
                                d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z"
                                clip-rule="evenodd"></path></svg
                        >
                        <a href="/blog/" class="hover:text-brand-600">Blog</a>
                    </div>
                </li>
                <li>
                    <div class="flex items-center">
                        <svg
                            class="w-3 h-3 text-slate-400 mx-1"
                            fill="currentColor"
                            viewBox="0 0 20 20"
                            ><path
                                fill-rule="evenodd"
                                d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z"
                                clip-rule="evenodd"></path></svg
                        >
                        <span
                            class="text-slate-400 truncate max-w-[200px]"
                            aria-current="page">{post.data.title}</span
                        >
                    </div>
                </li>
            </ol>
        </nav>

        <!-- Header info -->
        <header class="mb-10 text-center md:text-left">
            <time
                datetime={post.data.publishDate}
                class="text-xs font-bold text-slate-400 uppercase tracking-wider block mb-2"
            >
                Published on {
                    new Date(post.data.publishDate).toLocaleDateString(
                        "en-US",
                        {
                            year: "numeric",
                            month: "long",
                            day: "numeric",
                        },
                    )
                }
            </time>
            <h1
                class="text-3xl md:text-4xl lg:text-5xl font-extrabold text-slate-900 tracking-tight leading-tight mb-4"
            >
                {post.data.title}
            </h1>
            <p class="text-lg text-slate-500 leading-relaxed max-w-3xl">
                {post.data.description}
            </p>
        </header>

        <!-- Markdown Render Container -->
        <article
            class="prose max-w-none text-slate-700 leading-relaxed space-y-6"
        >
            <Content />
        </article>

        <!-- Post Footer: Recommended Actions -->
        <div class="mt-16 pt-8 border-t border-slate-200">
            <div
                class="bg-gradient-to-r from-brand-500 to-brand-600 rounded-2xl p-6 md:p-8 text-white shadow-lg flex flex-col md:flex-row items-center justify-between"
            >
                <div class="mb-6 md:mb-0 max-w-xl text-center md:text-left">
                    <h3 class="text-xl md:text-2xl font-bold">
                        Try our free generator tools
                    </h3>
                    <p class="text-white/80 mt-1 text-sm">
                        Generate unlimited custom, standard compliant QR codes
                        and barcodes. 100% private & client-side.
                    </p>
                </div>
                <div
                    class="flex flex-col sm:flex-row space-y-3 sm:space-y-0 sm:space-x-3 w-full md:w-auto"
                >
                    <a
                        href="/qr-code-generator/"
                        class="bg-white text-brand-600 font-bold px-5 py-3 rounded-xl hover:bg-slate-50 transition-colors text-center text-sm"
                    >
                        QR Generator
                    </a>
                    <a
                        href="/barcode-generator/"
                        class="bg-brand-900 text-white font-bold px-5 py-3 rounded-xl hover:bg-brand-999 transition-colors text-center text-sm border border-brand-800"
                    >
                        Barcode Generator
                    </a>
                </div>
            </div>
        </div>
    </div>
</BaseLayout>

<style is:global>
    /* Markdown style custom injections */
    .prose h2 {
        @apply text-2xl font-bold text-slate-900 mt-10 mb-4 pb-2 border-b border-slate-100;
    }
    .prose h3 {
        @apply text-xl font-bold text-slate-900 mt-6 mb-3;
    }
    .prose p {
        @apply text-slate-600 text-base leading-relaxed mb-4;
    }
    .prose ul,
    .prose ol {
        @apply my-4 pl-6 space-y-2 text-slate-600 text-base list-disc;
    }
    .prose ol {
        @apply list-decimal;
    }
    .prose blockquote {
        @apply border-l-4 border-brand-400 bg-brand-50/50 pl-4 py-2 my-4 text-slate-600 rounded-r-lg;
    }
    .prose table {
        @apply w-full border-collapse my-6 text-left text-sm;
    }
    .prose table th {
        @apply bg-slate-100 text-slate-800 font-bold px-4 py-3 border-b border-slate-200;
    }
    .prose table td {
        @apply px-4 py-3 border-b border-slate-100 text-slate-600;
    }
    .prose strong {
        @apply font-semibold text-slate-900;
    }
    .prose code {
        @apply bg-slate-100 text-slate-800 text-sm px-1.5 py-0.5 rounded font-mono font-semibold;
    }
</style>
