---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const posts = await getCollection("blog");
// 按发布日期降序排序
const sortedPosts = posts.sort(
    (a, b) =>
        new Date(b.data.publishDate).getTime() -
        new Date(a.data.publishDate).getTime(),
);

const title = "QR & Barcode Guides - Blog | QR Barcode Tools";
const description =
    "Learn everything about QR codes and barcodes. Helpful guides on static vs dynamic codes, barcode verification, checksums, and printing best practices.";
---

<BaseLayout title={title} description={description}>
    <!-- Hero Banner -->
    <section
        class="bg-gradient-to-b from-brand-50 to-white pt-16 pb-12 border-b border-slate-100"
    >
        <div
            class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center md:text-left"
        >
            <h1 class="text-4xl font-extrabold text-slate-900 tracking-tight">
                QR & Barcode <span class="text-gradient">Guides</span>
            </h1>
            <p class="text-slate-600 mt-3 text-lg max-w-2xl leading-relaxed">
                Discover expert tips, format tutorials, and compliance
                specifications to help you design, print, and implement barcodes
                and QR codes successfully.
            </p>
        </div>
    </section>

    <!-- Post Grid -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            {
                sortedPosts.map((post) => (
                    <article class="bg-white rounded-2xl border border-slate-200/80 shadow-sm hover:shadow-md transition-shadow p-6 flex flex-col justify-between">
                        <div class="space-y-3">
                            <time
                                datetime={post.data.publishDate}
                                class="text-xs font-semibold text-slate-400"
                            >
                                {new Date(
                                    post.data.publishDate,
                                ).toLocaleDateString("en-US", {
                                    year: "numeric",
                                    month: "long",
                                    day: "numeric",
                                })}
                            </time>
                            <h2 class="text-xl font-bold text-slate-900 line-clamp-2 hover:text-brand-600 transition-colors">
                                <a href={`/blog/${post.slug}/`}>
                                    {post.data.title}
                                </a>
                            </h2>
                            <p class="text-sm text-slate-500 line-clamp-3 leading-relaxed">
                                {post.data.description}
                            </p>
                        </div>

                        <div class="pt-6 mt-6 border-t border-slate-100 flex items-center justify-between">
                            <span class="text-xs font-bold text-slate-400 uppercase tracking-wider">
                                Guide
                            </span>
                            <a
                                href={`/blog/${post.slug}/`}
                                class="text-sm font-bold text-brand-600 hover:text-brand-700 inline-flex items-center"
                            >
                                Read Article &rarr;
                            </a>
                        </div>
                    </article>
                ))
            }
        </div>
    </section>
</BaseLayout>
